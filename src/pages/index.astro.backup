</Layout>

<style>
	/* Hero Section */
	.hero-section {
		position: relative;
		background: #000000;
		color: #ffffff;
		min-height: 100vh;
		display: flex;
		align-items: center;
		padding: 8rem 2rem 4rem;
		overflow: hidden;
	}

	.hero-pattern {
		position: absolute;
		inset: 0;
		opacity: 0.03;
		background-image: radial-gradient(
			circle at 2px 2px,
			#ffffff 1px,
			transparent 0
		);
		background-size: 40px 40px;
	}

	.hero-container {
		max-width: 90rem;
		margin: 0 auto;
		width: 100%;
		position: relative;
		z-index: 10;
	}

	.hero-label {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		color: #ff5c00;
		margin-bottom: 3rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.separator {
		color: rgba(255, 255, 255, 0.3);
	}

	.hero-heading {
		font-size: clamp(3rem, 12vw, 9rem);
		font-weight: 800;
		line-height: 0.9;
		letter-spacing: -0.02em;
		margin-bottom: 2.5rem;
		text-transform: uppercase;
	}

	.hero-heading-line {
		display: block;
	}

	.hero-heading-accent {
		color: #ff5c00;
		font-style: italic;
	}

	.hero-description {
		font-size: 15px;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.6);
		margin-bottom: 3rem;
		max-width: 600px;
	}

	.hero-cta {
		background: #ff5c00;
		color: #000000;
		border: none;
		padding: 1.125rem 2.5rem;
		font-size: 11px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		cursor: pointer;
		transition: background 0.2s;
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		border-radius: 0;
		margin-bottom: 6rem;
	}

	.hero-cta:hover {
		background: #ffffff;
	}

	.hero-stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 3rem;
		padding-top: 3rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		max-width: 1200px;
	}

	.hero-stat {
		text-align: left;
	}

	.hero-stat-number {
		font-size: 2.5rem;
		font-weight: 800;
		margin-bottom: 0.5rem;
		color: #ffffff;
	}

	.hero-stat-label {
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: rgba(255, 255, 255, 0.4);
	}

	.hero-scroll {
		background: none;
		border: none;
		color: rgba(255, 255, 255, 0.4);
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0;
		transition: color 0.2s;
	}

	.hero-scroll:hover {
		color: #ff5c00;
	}

	/* Services Section */
	.services-section {
		background: #ffffff;
		padding: 6rem 2rem;
		border-bottom: 1px solid rgba(0, 0, 0, 0.08);
	}

	.services-container {
		max-width: 90rem;
		margin: 0 auto;
	}

	.services-header {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		margin-bottom: 5rem;
	}

	@media (min-width: 1024px) {
		.services-header {
			grid-template-columns: 1fr 1fr;
			gap: 6rem;
		}
	}

	.services-label {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		color: #ff5c00;
		display: block;
		margin-bottom: 2rem;
	}

	.services-title {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		font-weight: 800;
		line-height: 1;
		letter-spacing: -0.02em;
	}

	.services-title-main {
		display: block;
		color: #000000;
	}

	.services-title-sub {
		display: block;
		color: rgba(0, 0, 0, 0.25);
	}

	.services-description {
		font-size: 15px;
		line-height: 1.7;
		color: rgba(0, 0, 0, 0.6);
		max-width: 500px;
	}

	.services-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	@media (min-width: 768px) {
		.services-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 3rem;
		}
	}

	.service-card {
		position: relative;
		padding: 2.5rem 0;
		border-top: 1px solid rgba(0, 0, 0, 0.08);
	}

	.service-number {
		position: absolute;
		top: 2.5rem;
		right: 0;
		font-size: 11px;
		font-weight: 700;
		color: #ff5c00;
		letter-spacing: 0.1em;
	}

	.service-icon {
		color: rgba(0, 0, 0, 0.4);
		margin-bottom: 1.5rem;
	}

	.service-card-title {
		font-size: 18px;
		font-weight: 800;
		margin-bottom: 1rem;
		line-height: 1.3;
	}

	.service-card-description {
		font-size: 14px;
		line-height: 1.7;
		color: rgba(0, 0, 0, 0.6);
	}

	/* Responsive */
	@media (max-width: 768px) {
		.hero-section {
			padding: 6rem 1.5rem 3rem;
		}

		.hero-heading {
			font-size: clamp(2.5rem, 10vw, 4rem);
		}

		.hero-stats {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.services-section {
			padding: 4rem 1.5rem;
		}
	}

	/* Venue Network Section */
	.venue-section {
		background: #000000;
		color: #ffffff;
		padding: 6rem 2rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}

	.venue-container {
		max-width: 90rem;
		margin: 0 auto;
	}

	.venue-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}

	@media (min-width: 1024px) {
		.venue-grid {
			grid-template-columns: 1fr 1fr;
			gap: 6rem;
		}
	}

	.venue-label {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		color: #ff5c00;
		display: block;
		margin-bottom: 2rem;
	}

	.venue-title {
		font-size: clamp(2.5rem, 6vw, 4rem);
		font-weight: 800;
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin-bottom: 1.5rem;
	}

	.venue-description {
		font-size: 15px;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.6);
		margin-bottom: 3rem;
		max-width: 500px;
	}

	.venue-stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		padding: 2rem 0;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		margin-bottom: 3rem;
	}

	.venue-stat-number {
		font-size: 2rem;
		font-weight: 800;
		margin-bottom: 0.5rem;
	}

	.venue-stat-label {
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: rgba(255, 255, 255, 0.5);
	}

	.venue-cta {
		background: transparent;
		color: #ffffff;
		border: 2px solid #ffffff;
		padding: 1rem 2rem;
		font-size: 11px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		cursor: pointer;
		transition: all 0.2s;
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		border-radius: 0;
	}

	.venue-cta:hover {
		background: #ffffff;
		color: #000000;
	}

	.venue-image-container {
		position: relative;
		border-radius: 0;
		overflow: hidden;
	}

	.venue-image {
		width: 100%;
		height: 500px;
		object-fit: cover;
		display: block;
	}

	.venue-tags {
		position: absolute;
		bottom: 1.5rem;
		left: 1.5rem;
		right: 1.5rem;
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.venue-tag {
		background: rgba(0, 0, 0, 0.8);
		backdrop-filter: blur(10px);
		color: #ffffff;
		padding: 0.625rem 1.25rem;
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		border-radius: 0;
		border: 1px solid rgba(255, 255, 255, 0.2);
	}

	@media (max-width: 1024px) {
		.venue-section {
			padding: 4rem 1.5rem;
		}

		.venue-stats {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.venue-image {
			height: 400px;
		}
	}

	/* Full Stack Section */
	.fullstack-section {
		background: #f9f9f7;
		padding: 5rem 2rem;
