---
import Layout from "../layouts/Layout.astro";
import Map from "../components/Map.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="NTV Pulse Clone - Denver Marketing">
	<!-- Hero Section -->
	<section class="hero-section">
		<div class="hero-pattern"></div>

		<div class="hero-container">
			<div class="hero-label">
				<span>PREMIUM MARKETING</span>
				<span class="separator">·</span>
				<span>DENVER, CO</span>
			</div>

			<h1 class="hero-heading">
				<span class="hero-heading-line">GET YOUR</span>
				<span class="hero-heading-line hero-heading-accent"
					>BUSINESS</span
				>
				<span class="hero-heading-line">NOTICED.</span>
			</h1>

			<p class="hero-description">
				Denver's sharpest advertising and digital marketing<br />
				team — on screens, on search, and everywhere<br />
				your customers are.
			</p>

			<button class="hero-cta">
				TALK TO OUR TEAM
				<svg
					width="16"
					height="16"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="3"
						d="M9 5l7 7-7 7"></path>
				</svg>
			</button>

			<div class="hero-stats">
				<div class="hero-stat">
					<div class="hero-stat-number">500+</div>
					<div class="hero-stat-label">Screens Deployed</div>
				</div>
				<div class="hero-stat">
					<div class="hero-stat-number">20+</div>
					<div class="hero-stat-label">Years of Expertise</div>
				</div>
				<div class="hero-stat">
					<div class="hero-stat-number">1,200+</div>
					<div class="hero-stat-label">Clients Served</div>
				</div>
				<button class="hero-scroll">
					SCROLL
					<svg
						width="12"
						height="12"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="3"
							d="M19 9l-7 7-7-7"></path>
					</svg>
				</button>
			</div>
		</div>
	</section>

	<!-- Services Section -->
	<section class="services-section">
		<div class="services-container">
			<!-- Header with split layout -->
			<div class="services-header">
				<div class="services-header-left">
					<span class="services-label">WHAT WE DO</span>
					<h2 class="services-title">
						<span class="services-title-main"
							>Local Advertising</span
						>
						<span class="services-title-sub">Built for Denver.</span
						>
					</h2>
				</div>
				<div class="services-header-right">
					<p class="services-description">
						From billboard access to full digital campaigns —
						everything your business needs to stand out and scale up
						in the Denver market.
					</p>
				</div>
			</div>

			<!-- Services Grid -->
			<div class="services-grid">
				<!-- Service 01 -->
				<div class="service-card">
					<div class="service-number">01</div>
					<div class="service-icon">
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<rect
								x="3"
								y="3"
								width="18"
								height="18"
								rx="2"
								stroke-width="1.5"></rect>
							<path d="M3 9h18M9 21V9" stroke-width="1.5"></path>
						</svg>
					</div>
					<h3 class="service-card-title">
						Indoor Billboard Advertising
					</h3>
					<p class="service-card-description">
						Own the room. High-impact digital screens placed inside
						Denver's busiest gyms, restaurants, and retail spaces.
					</p>
				</div>

				<!-- Service 02 -->
				<div class="service-card">
					<div class="service-number">02</div>
					<div class="service-icon">
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
							></path>
						</svg>
					</div>
					<h3 class="service-card-title">Social Media Marketing</h3>
					<p class="service-card-description">
						Scroll-stopping content that builds communities and
						turns followers into paying customers.
					</p>
				</div>

				<!-- Service 03 -->
				<div class="service-card">
					<div class="service-number">03</div>
					<div class="service-icon">
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<circle cx="12" cy="12" r="10" stroke-width="1.5"
							></circle>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M2 12h20"></path>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"
							></path>
						</svg>
					</div>
					<h3 class="service-card-title">Custom Website Design</h3>
					<p class="service-card-description">
						Blazing-fast, beautifully-crafted websites engineered to
						convert visitors into loyal clients.
					</p>
				</div>

				<!-- Service 04 -->
				<div class="service-card">
					<div class="service-number">04</div>
					<div class="service-icon">
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<circle cx="12" cy="12" r="3" stroke-width="1.5"
							></circle>
							<circle cx="12" cy="12" r="8" stroke-width="1.5"
							></circle>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M12 2v4m0 12v4M2 12h4m12 0h4"></path>
						</svg>
					</div>
					<h3 class="service-card-title">Targeted Lead Generation</h3>
					<p class="service-card-description">
						Precision-targeted campaigns across Google and social
						that hit your pipeline with quality leads.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Venue Network Section -->
	<section class="venue-section">
		<div class="venue-container">
			<div class="venue-grid">
				<!-- Left: Content -->
				<div class="venue-content">
					<span class="venue-label">VENUE NETWORK</span>
					<h2 class="venue-title">
						Denver's Most<br />Coveted Locations.
					</h2>
					<p class="venue-description">
						We've built an exclusive network inside Denver's
						highest-traffic venues — where your audience is already
						present, relaxed, and receptive.
					</p>

					<!-- Stats -->
					<div class="venue-stats">
						<div class="venue-stat">
							<div class="venue-stat-number">80+</div>
							<div class="venue-stat-label">Active Venues</div>
						</div>
						<div class="venue-stat">
							<div class="venue-stat-number">2.4M</div>
							<div class="venue-stat-label">
								Monthly Impressions
							</div>
						</div>
						<div class="venue-stat">
							<div class="venue-stat-number">15+</div>
							<div class="venue-stat-label">Neighborhoods</div>
						</div>
					</div>

					<button class="venue-cta">
						VIEW ALL VENUES
						<svg
							width="14"
							height="14"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="3"
								d="M9 5l7 7-7 7"></path>
						</svg>
					</button>
				</div>

				<!-- Right: Image with Tags -->
				<div class="venue-image-container">
					<img
						src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=800&q=80"
						alt="Fitness studio with equipment"
						class="venue-image"
					/>
					<div class="venue-tags">
						<span class="venue-tag">Fitness Studios</span>
						<span class="venue-tag">Restaurants</span>
						<span class="venue-tag">Retail Stores</span>
						<span class="venue-tag">Medical Offices</span>
						<span class="venue-tag">Coworking Spaces</span>
						<span class="venue-tag">Hotel Lobbies</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Full Stack Section -->
	<section class="fullstack-section">
		<div class="fullstack-container">
			<div class="fullstack-grid">
				<!-- Left: Content + Image -->
				<div class="fullstack-left">
					<span class="fullstack-label">FULL STACK</span>
					<h2 class="fullstack-title">
						Complete<br />Digital<br />Coverage.
					</h2>
					<p class="fullstack-description">
						Beyond screens, we run the full playbook — from your
						Google presence to paid campaigns that drive real
						revenue.
					</p>

					<!-- Image with Tag -->
					<div class="fullstack-image-container">
						<img
							src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&q=80"
							alt="Team collaboration"
							class="fullstack-image"
						/>
						<span class="fullstack-image-tag">DENVER PROS</span>
					</div>
				</div>

				<!-- Right: Services List -->
				<div class="fullstack-right">
					<div class="fullstack-services">
						<!-- Service 01 -->
						<div class="fullstack-service">
							<div class="fullstack-service-number">01</div>
							<div class="fullstack-service-content">
								<h3 class="fullstack-service-title">
									Google Business Profile
								</h3>
								<p class="fullstack-service-description">
									Dominate local search results and appear at
									the top of Google Maps.
								</p>
							</div>
						</div>

						<!-- Service 02 -->
						<div class="fullstack-service">
							<div class="fullstack-service-number">02</div>
							<div class="fullstack-service-content">
								<h3 class="fullstack-service-title">
									Website Design & Dev
								</h3>
								<p class="fullstack-service-description">
									Lightning-fast sites built around your brand
									and conversion goals.
								</p>
							</div>
						</div>

						<!-- Service 03 -->
						<div class="fullstack-service">
							<div class="fullstack-service-number">03</div>
							<div class="fullstack-service-content">
								<h3 class="fullstack-service-title">
									Social Media Strategy
								</h3>
								<p class="fullstack-service-description">
									Cohesive content ecosystems that grow,
									engage, and convert.
								</p>
							</div>
						</div>

						<!-- Service 04 -->
						<div class="fullstack-service">
							<div class="fullstack-service-number">04</div>
							<div class="fullstack-service-content">
								<h3 class="fullstack-service-title">
									PPC Management
								</h3>
								<p class="fullstack-service-description">
									Every ad dollar optimized for maximum return
									on investment.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Why Apex Section -->
	<section class="why-section">
		<div class="why-container">
			<!-- Header -->
			<div class="why-header">
				<div class="why-header-left">
					<span class="why-label">WHY APEX</span>
					<h2 class="why-title">
						<span class="why-title-main">Not Just Another</span>
						<span class="why-title-sub">Agency.</span>
					</h2>
				</div>
				<div class="why-header-right">
					<button class="why-cta">
						GET STARTED TODAY
						<svg
							width="14"
							height="14"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="3"
								d="M9 5l7 7-7 7"></path>
						</svg>
					</button>
				</div>
			</div>

			<!-- Cards Grid -->
			<div class="why-grid">
				<!-- Card 01 -->
				<div class="why-card">
					<div class="why-card-number">01</div>
					<h3 class="why-card-title">Local Expertise</h3>
					<p class="why-card-description">
						We know Denver's neighborhoods, venues, and customer
						behavior better than anyone.
					</p>
				</div>

				<!-- Card 02 -->
				<div class="why-card">
					<div class="why-card-number">02</div>
					<h3 class="why-card-title">Measurable Results</h3>
					<p class="why-card-description">
						Transparent reporting and real KPIs — you always know
						exactly what you're getting.
					</p>
				</div>

				<!-- Card 03 -->
				<div class="why-card">
					<div class="why-card-number">03</div>
					<h3 class="why-card-title">Full-Service Team</h3>
					<p class="why-card-description">
						One team handles everything: from creative to campaign
						management. No juggling agencies.
					</p>
				</div>

				<!-- Card 04 -->
				<div class="why-card">
					<div class="why-card-number">04</div>
					<h3 class="why-card-title">Honest Partnership</h3>
					<p class="why-card-description">
						We treat your budget like our own and only recommend
						what actually works for you.
					</p>
				</div>
			</div>

			<!-- Quote -->
			<div class="why-quote">
				<p>
					"We're <strong>Denver marketing pros</strong> and locals who understand
					the market, know the neighborhoods, and have the relationships
					that <span class="why-quote-highlight">get results</span>."
				</p>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="cta-banner">
		<div class="cta-banner-container">
			<div class="cta-banner-grid">
				<div class="cta-banner-left">
					<h2 class="cta-banner-title">
						Ready to Dominate<br />Your Market?
					</h2>
				</div>
				<div class="cta-banner-right">
					<p class="cta-banner-description">
						Free 30-minute strategy session. No commitment, no
						pressure — just a real conversation about your growth.
					</p>
					<button class="cta-banner-button">
						SCHEDULE FREE CONSULTATION
						<svg
							width="14"
							height="14"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="3"
								d="M9 5l7 7-7 7"></path>
						</svg>
					</button>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<section class="faq-section">
		<div class="faq-container">
			<div class="faq-grid">
				<!-- Left: Header -->
				<div class="faq-header">
					<span class="faq-label">FAQS</span>
					<h2 class="faq-title">
						Common<br />Questions.
					</h2>
				</div>

				<!-- Right: Accordion -->
				<div class="faq-list">
					<!-- FAQ 1 -->
					<div class="faq-item faq-item-open">
						<button class="faq-item-button">
							<span class="faq-item-question"
								>What is Indoor Digital Signage Advertising?</span
							>
							<div class="faq-item-icon">
								<svg
									width="24"
									height="24"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M20 12H4"></path>
								</svg>
							</div>
						</button>
						<div class="faq-item-answer">
							<p>
								It's the placement of your ads on HD screens
								inside high-traffic venues — gyms, restaurants,
								offices — where your audience is already
								present, engaged, and receptive to your message.
							</p>
						</div>
					</div>

					<!-- FAQ 2 -->
					<div class="faq-item">
						<button class="faq-item-button">
							<span class="faq-item-question"
								>Do you offer bundled screen + digital packages?</span
							>
							<div class="faq-item-icon">
								<svg
									width="24"
									height="24"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M12 4v16m8-8H4"></path>
								</svg>
							</div>
						</button>
						<div class="faq-item-answer hidden">
							<p>
								Yes! We offer comprehensive marketing packages
								that combine indoor digital signage with online
								advertising campaigns for maximum reach and
								impact.
							</p>
						</div>
					</div>

					<!-- FAQ 3 -->
					<div class="faq-item">
						<button class="faq-item-button">
							<span class="faq-item-question"
								>Can you help my business rank on Google?</span
							>
							<div class="faq-item-icon">
								<svg
									width="24"
									height="24"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M12 4v16m8-8H4"></path>
								</svg>
							</div>
						</button>
						<div class="faq-item-answer hidden">
							<p>
								Absolutely! Our digital marketing services
								include Google Business Profile optimization,
								local SEO strategies, and PPC campaign
								management to improve your visibility.
							</p>
						</div>
					</div>

					<!-- FAQ 4 -->
					<div class="faq-item">
						<button class="faq-item-button">
							<span class="faq-item-question"
								>How quickly will I see results?</span
							>
							<div class="faq-item-icon">
								<svg
									width="24"
									height="24"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M12 4v16m8-8H4"></path>
								</svg>
							</div>
						</button>
						<div class="faq-item-answer hidden">
							<p>
								Results vary by service. Indoor advertising
								campaigns show immediate brand visibility, while
								digital marketing efforts like SEO may take 3-6
								months for significant results.
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<script>
		document.addEventListener("DOMContentLoaded", () => {
			const faqButtons = document.querySelectorAll(".faq-item-button");

			faqButtons.forEach((button) => {
				button.addEventListener("click", () => {
					const faqItem = button.closest(".faq-item");
					const answer = faqItem?.querySelector(".faq-item-answer");
					const icon = button.querySelector(".faq-item-icon svg");

					if (answer && icon) {
						const isOpen =
							faqItem?.classList.contains("faq-item-open");

						// Close all items
						document
							.querySelectorAll(".faq-item")
							.forEach((item) => {
								item.classList.remove("faq-item-open");
								item.querySelector(
									".faq-item-answer",
								)?.classList.add("hidden");
							});

						// Open clicked item if it was closed
						if (!isOpen) {
							faqItem?.classList.add("faq-item-open");
							answer.classList.remove("hidden");
						}
					}
				});
			});
		});
	</script>

	<!-- Coverage Area / Map Section -->
	<section class="map-section">
		<div class="map-container">
			<!-- Header -->
			<div class="map-header">
				<div class="map-header-left">
					<span class="map-label">COVERAGE AREA</span>
					<h2 class="map-title">
						<span class="map-title-main">We Put Local</span>
						<span class="map-title-sub">Brands on the Map.</span>
					</h2>
				</div>
				<div class="map-header-right">
					<p class="map-description">
						Our screen network spans Denver's most vibrant
						neighborhoods — click a location to explore.
					</p>
				</div>
			</div>

			<!-- Map Grid -->
			<div class="map-grid">
				<!-- Left: Location Cards -->
				<div class="map-locations">
					<!-- Aurora - Expanded -->
					<button
						class="map-location-card map-location-active"
						onclick="flyToCity(39.7294, -104.8319, 'Aurora', 'East Metro')"
					>
						<div class="map-location-header">
							<div class="map-location-tag">EAST METRO</div>
							<div class="map-location-icon">
								<svg
									width="20"
									height="20"
									fill="currentColor"
									viewBox="0 0 20 20"
								>
									<path
										fill-rule="evenodd"
										d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
										clip-rule="evenodd"></path>
								</svg>
							</div>
						</div>
						<h3 class="map-location-name">Aurora</h3>
						<p class="map-location-description">
							Denver's largest suburb — massive reach across busy
							retail corridors and fitness centers.
						</p>
						<div class="map-location-stats">
							<div class="map-location-stat">
								<div class="map-location-stat-number">38</div>
								<div class="map-location-stat-label">
									Screens
								</div>
							</div>
							<div class="map-location-stat">
								<div class="map-location-stat-number">14</div>
