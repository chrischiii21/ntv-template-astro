---
import Layout from "../layouts/Layout.astro";
import Map from "../components/Map.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="NTV Clone - Denver Marketing">
	<!-- Hero Section -->
	<section
		class="relative bg-black text-white min-h-screen flex items-center px-6 py-24 pb-12 overflow-hidden md:px-8 md:py-32 md:pb-16"
	>
		<!-- Pattern Background -->
		<div
			class="absolute inset-0 opacity-[0.03] bg-[radial-gradient(circle_at_2px_2px,#ffffff_1px,transparent_0)] bg-[length:40px_40px]"
		>
		</div>

		<div class="max-w-[90rem] mx-auto w-full relative z-10">
			<!-- Label -->
			<div
				class="text-[11px] font-bold uppercase tracking-label text-[#ff5c00] mb-12 flex items-center gap-3"
			>
				<span>PREMIUM MARKETING</span>
				<span class="text-white/30">·</span>
				<span>DENVER, CO</span>
			</div>

			<!-- Heading -->
			<h1
				class="font-display text-[clamp(2.5rem,10vw,4rem)] md:text-[clamp(3rem,12vw,9rem)] font-bold leading-[0.9] tracking-tighter mb-10 uppercase"
			>
				<span class="block">GET YOUR</span>
				<span class="block text-[#ff5c00] italic">BUSINESS</span>
				<span class="block">NOTICED.</span>
			</h1>

			<!-- Description -->
			<p
				class="text-[15px] leading-[1.7] text-white/60 mb-16 max-w-[600px]"
			>
				Denver's sharpest advertising and digital marketing<br />
				team — on screens, on search, and everywhere<br />
				your customers are.
			</p>

			<!-- CTA Button -->
			<button
				class="bg-[#ff5c00] text-black border-none px-10 py-[1.125rem] text-[11px] font-bold uppercase tracking-button cursor-pointer transition-colors duration-200 inline-flex items-center gap-3 rounded-none mb-24 hover:bg-white"
			>
				TALK TO OUR TEAM
				<svg
					width="16"
					height="16"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="3"
						d="M9 5l7 7-7 7"></path>
				</svg>
			</button>

			<!-- Stats -->
			<div
				class="grid grid-cols-1 md:grid-cols-[repeat(auto-fit,minmax(200px,1fr))] gap-8 md:gap-12 pt-16 border-t border-white/10 max-w-[1200px]"
			>
				<div class="text-left">
					<div class="text-[2.5rem] font-extrabold mb-2 text-white">
						500+
					</div>
					<div
						class="text-[11px] font-semibold uppercase tracking-[0.15em] text-white/40"
					>
						Screens Deployed
					</div>
				</div>
				<div class="text-left">
					<div class="text-[2.5rem] font-extrabold mb-2 text-white">
						20+
					</div>
					<div
						class="text-[11px] font-semibold uppercase tracking-[0.15em] text-white/40"
					>
						Years of Expertise
					</div>
				</div>
				<div class="text-left">
					<div class="text-[2.5rem] font-extrabold mb-2 text-white">
						1,200+
					</div>
					<div
						class="text-[11px] font-semibold uppercase tracking-[0.15em] text-white/40"
					>
						Clients Served
					</div>
				</div>
				<button
					class="bg-transparent border-none text-white/40 text-[10px] font-bold uppercase tracking-button cursor-pointer flex items-center gap-2 p-0 transition-colors duration-200 hover:text-[#ff5c00]"
				>
					SCROLL
					<svg
						width="12"
						height="12"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="3"
							d="M19 9l-7 7-7-7"></path>
					</svg>
				</button>
			</div>
		</div>
	</section>

	<!-- Services Section -->
	<section
		class="bg-white px-8 py-28 border-b border-black/[0.08] md:px-8 md:py-28 max-md:px-6 max-md:py-20"
	>
		<div class="max-w-[90rem] mx-auto">
			<!-- Header with split layout -->
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 mb-24">
				<div>
					<span
						class="text-[11px] font-bold uppercase tracking-label text-[#ff5c00] block mb-10"
						>WHAT WE DO</span
					>
					<h2
						class="font-display text-[clamp(2.5rem,6vw,4.5rem)] font-bold leading-display tracking-tighter"
					>
						<span class="block text-black">Local Advertising</span>
						<span class="block text-black/25"
							>Built for Denver.</span
						>
					</h2>
				</div>
				<div>
					<p
						class="text-[15px] leading-[1.7] text-black/60 max-w-[500px]"
					>
						From billboard access to full digital campaigns —
						everything your business needs to stand out and scale up
						in the Denver market.
					</p>
				</div>
			</div>

			<!-- Services Grid -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16">
				<!-- Service 01 -->
				<div class="relative pt-12 pb-0 border-t border-black/[0.08]">
					<div
						class="absolute top-12 right-0 text-[11px] font-bold text-[#ff5c00] tracking-[0.1em]"
					>
						01
					</div>
					<div class="text-black/40 mb-8">
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<rect
								x="3"
								y="3"
								width="18"
								height="18"
								rx="2"
								stroke-width="1.5"></rect>
							<path d="M3 9h18M9 21V9" stroke-width="1.5"></path>
						</svg>
					</div>
					<h3 class="text-[18px] font-bold mb-5 leading-heading">
						Indoor Billboard Advertising
					</h3>
					<p class="text-[14px] leading-[1.7] text-black/60">
						Own the room. High-impact digital screens placed inside
						Denver's busiest gyms, restaurants, and retail spaces.
					</p>
				</div>

				<!-- Service 02 -->
				<div class="relative pt-12 pb-0 border-t border-black/[0.08]">
					<div
						class="absolute top-12 right-0 text-[11px] font-bold text-[#ff5c00] tracking-[0.1em]"
					>
						02
					</div>
					<div class="text-black/40 mb-8">
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
							></path>
						</svg>
					</div>
					<h3 class="text-[18px] font-bold mb-5 leading-heading">
						Social Media Marketing
					</h3>
					<p class="text-[14px] leading-[1.7] text-black/60">
						Scroll-stopping content that builds communities and
						turns followers into paying customers.
					</p>
				</div>

				<!-- Service 03 -->
				<div class="relative pt-12 pb-0 border-t border-black/[0.08]">
					<div
						class="absolute top-12 right-0 text-[11px] font-bold text-[#ff5c00] tracking-[0.1em]"
					>
						03
					</div>
					<div class="text-black/40 mb-8">
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<circle cx="12" cy="12" r="10" stroke-width="1.5"
							></circle>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M2 12h20"></path>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"
							></path>
						</svg>
					</div>
					<h3 class="text-[18px] font-bold mb-5 leading-heading">
						Custom Website Design
					</h3>
					<p class="text-[14px] leading-[1.7] text-black/60">
						Blazing-fast, beautifully-crafted websites engineered to
						convert visitors into loyal clients.
					</p>
				</div>

				<!-- Service 04 -->
				<div class="relative pt-12 pb-0 border-t border-black/[0.08]">
					<div
						class="absolute top-12 right-0 text-[11px] font-bold text-[#ff5c00] tracking-[0.1em]"
					>
						04
					</div>
					<div class="text-black/40 mb-8">
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<circle cx="12" cy="12" r="3" stroke-width="1.5"
							></circle>
							<circle cx="12" cy="12" r="8" stroke-width="1.5"
							></circle>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M12 2v4m0 12v4M2 12h4m12 0h4"></path>
						</svg>
					</div>
					<h3 class="text-[18px] font-bold mb-5 leading-heading">
						Targeted Lead Generation
					</h3>
					<p class="text-[14px] leading-[1.7] text-black/60">
						Precision-targeted campaigns across Google and social
						that hit your pipeline with quality leads.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Venue Network Section -->
	<section
		class="bg-black text-white px-8 py-28 border-b border-white/10 max-lg:px-6 max-lg:py-20"
	>
		<div class="max-w-[90rem] mx-auto">
			<div
				class="grid grid-cols-1 lg:grid-cols-2 gap-20 lg:gap-28 items-center"
			>
				<!-- Left: Content -->
				<div>
					<span
						class="text-[11px] font-bold uppercase tracking-label text-[#ff5c00] block mb-10"
						>VENUE NETWORK</span
					>
					<h2
						class="font-display text-[clamp(2.5rem,6vw,4rem)] font-bold leading-display tracking-tighter mb-8"
					>
						Denver's Most<br />Coveted Locations.
					</h2>
					<p
						class="text-[15px] leading-[1.7] text-white/60 mb-16 max-w-[500px]"
					>
						We've built an exclusive network inside Denver's
						highest-traffic venues — where your audience is already
						present, relaxed, and receptive.
					</p>

					<!-- Stats -->
					<div
						class="grid grid-cols-3 max-lg:grid-cols-1 gap-8 max-lg:gap-6 py-10 border-t border-b border-white/10 mb-16"
					>
						<div>
							<div class="text-[2rem] font-extrabold mb-2">
								80+
							</div>
							<div
								class="text-[11px] font-semibold uppercase tracking-[0.1em] text-white/50"
							>
								Active Venues
							</div>
						</div>
						<div>
							<div class="text-[2rem] font-extrabold mb-2">
								2.4M
							</div>
							<div
								class="text-[11px] font-semibold uppercase tracking-[0.1em] text-white/50"
							>
								Monthly Impressions
							</div>
						</div>
						<div>
							<div class="text-[2rem] font-extrabold mb-2">
								15+
							</div>
							<div
								class="text-[11px] font-semibold uppercase tracking-[0.1em] text-white/50"
							>
								Neighborhoods
							</div>
						</div>
					</div>

					<button
						class="bg-transparent text-white border-2 border-white px-8 py-4 text-[11px] font-bold uppercase tracking-button cursor-pointer transition-all duration-200 inline-flex items-center gap-3 rounded-none hover:bg-white hover:text-black"
					>
						VIEW ALL VENUES
						<svg
							width="14"
							height="14"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="3"
								d="M9 5l7 7-7 7"></path>
						</svg>
					</button>
				</div>

				<!-- Right: Image with Tags -->
				<div class="relative rounded-none overflow-hidden">
					<img
						src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=800&q=80"
						alt="Fitness studio with equipment"
						class="w-full h-[500px] max-lg:h-[400px] object-cover block"
					/>
					<div
						class="absolute bottom-6 left-6 right-6 flex flex-wrap gap-3"
					>
						<span
							class="bg-black/80 backdrop-blur-[10px] text-white px-5 py-2.5 text-[11px] font-bold uppercase tracking-[0.1em] rounded-none border border-white/20"
							>Fitness Studios</span
						>
						<span
							class="bg-black/80 backdrop-blur-[10px] text-white px-5 py-2.5 text-[11px] font-bold uppercase tracking-[0.1em] rounded-none border border-white/20"
							>Restaurants</span
						>
						<span
							class="bg-black/80 backdrop-blur-[10px] text-white px-5 py-2.5 text-[11px] font-bold uppercase tracking-[0.1em] rounded-none border border-white/20"
							>Retail Stores</span
						>
						<span
							class="bg-black/80 backdrop-blur-[10px] text-white px-5 py-2.5 text-[11px] font-bold uppercase tracking-[0.1em] rounded-none border border-white/20"
							>Medical Offices</span
						>
						<span
							class="bg-black/80 backdrop-blur-[10px] text-white px-5 py-2.5 text-[11px] font-bold uppercase tracking-[0.1em] rounded-none border border-white/20"
							>Coworking Spaces</span
						>
						<span
							class="bg-black/80 backdrop-blur-[10px] text-white px-5 py-2.5 text-[11px] font-bold uppercase tracking-[0.1em] rounded-none border border-white/20"
							>Hotel Lobbies</span
						>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Full Stack Section -->
	<section
		class="bg-[#f9f9f7] px-8 py-28 border-b border-black/[0.08] max-lg:px-6 max-lg:py-20"
	>
		<div class="max-w-[90rem] mx-auto">
			<div
				class="grid grid-cols-1 lg:grid-cols-[45%_55%] xl:grid-cols-[42%_58%] gap-16 lg:gap-20 xl:gap-18 items-start"
			>
				<!-- Left: Content + Image -->
				<div class="flex flex-col">
					<span
						class="text-[11px] font-bold uppercase tracking-label text-[#ff5c00] block mb-8"
						>FULL STACK</span
					>
					<h2
						class="font-display text-[clamp(2.25rem,5vw,3.5rem)] lg:text-[3rem] xl:text-[3.5rem] font-bold leading-display tracking-tighter mb-6"
					>
						Complete<br />Digital<br />Coverage.
					</h2>
					<p
						class="text-[14px] leading-[1.65] text-black/60 mb-12 max-w-[420px]"
					>
						Beyond screens, we run the full playbook — from your
						Google presence to paid campaigns that drive real
						revenue.
					</p>

					<!-- Image with Tag -->
					<div
						class="relative rounded-none overflow-hidden w-full max-w-[420px]"
					>
						<img
							src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&q=80"
							alt="Team collaboration"
							class="w-full h-[260px] max-lg:h-[240px] object-cover block"
						/>
						<span
							class="absolute bottom-5 left-5 bg-[#ff5c00] text-black px-5 py-2.5 text-[10px] font-extrabold uppercase tracking-[0.15em] rounded-none"
							>DENVER PROS</span
						>
					</div>
				</div>

				<!-- Right: Services List -->
				<div class="flex flex-col justify-start">
					<div class="flex flex-col gap-0">
						<!-- Service 01 -->
						<div
							class="flex gap-7 py-8 max-lg:py-7 border-t border-black/[0.08] items-start"
						>
							<div
								class="text-[13px] font-bold text-[#ff5c00] shrink-0 w-8 pt-0.5"
							>
								01
							</div>
							<div class="flex-1">
								<h3
									class="text-[18px] font-extrabold mb-2 leading-[1.3] tracking-[-0.01em]"
								>
									Google Business Profile
								</h3>
								<p
									class="text-[13px] leading-[1.65] text-black/60"
								>
									Dominate local search results and appear at
									the top of Google Maps.
								</p>
							</div>
						</div>

						<!-- Service 02 -->
						<div
							class="flex gap-7 py-8 max-lg:py-7 border-t border-black/[0.08] items-start"
						>
							<div
								class="text-[13px] font-bold text-[#ff5c00] shrink-0 w-8 pt-0.5"
							>
								02
							</div>
							<div class="flex-1">
								<h3
									class="text-[18px] font-extrabold mb-2 leading-[1.3] tracking-[-0.01em]"
								>
									Website Design & Dev
								</h3>
								<p
									class="text-[13px] leading-[1.65] text-black/60"
								>
									Lightning-fast sites built around your brand
									and conversion goals.
								</p>
							</div>
						</div>

						<!-- Service 03 -->
						<div
							class="flex gap-7 py-8 max-lg:py-7 border-t border-black/[0.08] items-start"
						>
							<div
								class="text-[13px] font-bold text-[#ff5c00] shrink-0 w-8 pt-0.5"
							>
								03
							</div>
							<div class="flex-1">
								<h3
									class="text-[18px] font-extrabold mb-2 leading-[1.3] tracking-[-0.01em]"
								>
									Social Media Strategy
								</h3>
								<p
									class="text-[13px] leading-[1.65] text-black/60"
								>
									Cohesive content ecosystems that grow,
									engage, and convert.
								</p>
							</div>
						</div>

						<!-- Service 04 -->
						<div
							class="flex gap-7 py-8 max-lg:py-7 pb-0 border-t border-black/[0.08] items-start"
						>
							<div
								class="text-[13px] font-bold text-[#ff5c00] shrink-0 w-8 pt-0.5"
							>
								04
							</div>
							<div class="flex-1">
								<h3
									class="text-[18px] font-extrabold mb-2 leading-[1.3] tracking-[-0.01em]"
								>
									PPC Management
								</h3>
								<p
									class="text-[13px] leading-[1.65] text-black/60"
								>
									Every ad dollar optimized for maximum return
									on investment.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Why Apex Section -->
	<section
		class="bg-black text-white px-8 py-28 border-b border-white/10 max-lg:px-6 max-lg:py-20"
	>
		<div class="max-w-[90rem] mx-auto">
			<!-- Header -->
			<div
				class="flex flex-col lg:flex-row gap-8 lg:justify-between lg:items-start mb-20 max-lg:mb-16"
			>
				<div>
					<span
						class="text-[11px] font-bold uppercase tracking-label text-[#ff5c00] block mb-8"
						>WHY APEX</span
					>
					<h2
						class="font-display text-[clamp(2.5rem,6vw,4.5rem)] font-bold leading-display tracking-tighter"
					>
						<span class="block text-white">Not Just Another</span>
						<span class="block text-white/25">Agency.</span>
					</h2>
				</div>
				<div class="flex items-start pt-2">
					<button
						class="bg-transparent text-white border-2 border-white px-8 py-4 text-[11px] font-bold uppercase tracking-button cursor-pointer transition-all duration-200 inline-flex items-center gap-3 rounded-none whitespace-nowrap hover:bg-white hover:text-black"
					>
						GET STARTED TODAY
						<svg
							width="14"
							height="14"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="3"
								d="M9 5l7 7-7 7"></path>
						</svg>
					</button>
				</div>
			</div>

			<!-- Cards Grid -->
			<div
				class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 sm:gap-12 lg:gap-10 mb-20 max-lg:mb-16"
			>
				<!-- Card 01 -->
				<div class="bg-transparent p-0">
					<div
						class="text-[16px] font-bold text-[#ff5c00] mb-8 tracking-[0.05em]"
					>
						01
					</div>
					<h3
						class="text-[20px] font-extrabold text-white mb-3 leading-[1.3] tracking-[-0.01em]"
					>
						Local Expertise
					</h3>
					<p class="text-[14px] leading-[1.65] text-white/60">
						We know Denver's neighborhoods, venues, and customer
						behavior better than anyone.
					</p>
				</div>

				<!-- Card 02 -->
				<div class="bg-transparent p-0">
					<div
						class="text-[16px] font-bold text-[#ff5c00] mb-8 tracking-[0.05em]"
					>
						02
					</div>
					<h3
						class="text-[20px] font-extrabold text-white mb-3 leading-[1.3] tracking-[-0.01em]"
					>
						Measurable Results
					</h3>
					<p class="text-[14px] leading-[1.65] text-white/60">
						Transparent reporting and real KPIs — you always know
