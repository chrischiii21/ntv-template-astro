---
import Layout from "../layouts/Layout.astro";
import Map from "../components/Map.astro";
import FloatingFreeScanButton from "../components/FloatingFreeScanButton.astro";
import "../styles/interactive.css";
---

<Layout title="NTV Cloned - Denver Marketing">
	<!-- Hero Section -->
	<section
		class="relative bg-black text-white min-h-screen flex items-center px-6 py-24 pb-12 overflow-hidden md:px-8 md:py-32 md:pb-16"
	>
		<!-- Background Image -->
		<div
			class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-25"
			style="background-image: url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1920&q=80&auto=format');"
		>
		</div>

		<!-- Pattern Background -->
		<div
			class="absolute inset-0 opacity-[0.03] bg-[radial-gradient(circle_at_2px_2px,#ffffff_1px,transparent_0)] bg-[length:40px_40px]"
		>
		</div>

		<!-- Gradient Overlay -->
		<div
			class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/60 to-black/40"
		>
		</div>

		<div class="max-w-[90rem] mx-auto w-full relative z-10">
			<!-- Label -->
			<div class="flex items-center gap-4">
				<div class="h-[2px] w-12 bg-[#06B6D4]"></div>

				<span
					class="text-sm font-bold uppercase tracking-[0.2em] text-[#06B6D4]"
				>
					Premium Marketing Solutions
				</span>
			</div>

			<!-- Heading -->
			<h1
				class="font-display text-[clamp(2rem,8vw,3.5rem)] md:text-[clamp(2.5rem,10vw,6rem)] font-bold leading-[0.95] tracking-tighter mb-10 uppercase"
			>
				<span class="block">Local Advertising &</span>
				<span class="block text-[#06B6D4] italic"
					>Digital Marketing</span
				>
				<span class="block">Pros in Denver</span>
			</h1>

			<!-- Description -->
			<div class="flex items-start gap-4 py-5 mb-16 max-w-[600px]">
				<svg
					class="w-6 h-6 text-white/60 mt-1 flex-shrink-0"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M7 17L17 7M17 7H7M17 7v10"></path>
				</svg>
				<p class="text-[18px] leading-[1.7] text-white/60">
					Helping Businesses Get Noticed—On Screens and Online
				</p>
			</div>

			<!-- CTA Button -->
			<button
				class="bg-[#06B6D4] text-black border-none px-10 py-[1.125rem] text-[11px] font-bold uppercase tracking-button cursor-pointer transition-all duration-300 inline-flex items-center gap-3 rounded-none mb-24 hover:scale-105 hover:shadow-lg hover:shadow-[#06B6D4]/50"
			>
				TALK TO OUR TEAM
				<svg
					width="16"
					height="16"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="3"
						d="M9 5l7 7-7 7"></path>
				</svg>
			</button>
		</div>
	</section>

	<!-- Services Section -->
	<section
		class="bg-white px-8 py-28 border-b border-black/[0.08] md:px-8 md:py-28 max-md:px-6 max-md:py-20"
	>
		<div class="max-w-[90rem] mx-auto">
			<!-- Header with split layout -->
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 mb-24">
				<div>
					<div class="flex items-center gap-4">
						<div class="h-[2px] w-12 bg-[#06B6D4]"></div>

						<span
							class="text-sm font-bold uppercase tracking-[0.2em] text-[#06B6D4]"
						>
							What we do
						</span>
					</div>
					<h2
						class="font-display text-[clamp(2.5rem,6vw,4.5rem)] font-bold leading-display tracking-tighter"
					>
						<span class="block text-black">Local Advertising</span>
						<span class="block text-black/25"
							>Built for Denver.</span
						>
					</h2>
				</div>
				<div>
					<p
						class="text-[18px] leading-[1.7] text-black/60 max-w-[500px] py-5 mb-10"
					>
						As your trusted <span class="font-bold text-[#06B6D4]"
							>Denver marketing pros</span
						>, our <span class="font-bold text-[#06B6D4]"
							>billboard network</span
						> gives you access to high-traffic locations where your ideal
						customers spend time. From gyms and restaurants to retail
						stores and office buildings, we help you get noticed in the
						moments that matter.
					</p>
					<button
						class="bg-[#06B6D4] text-black border-none px-10 py-[1.125rem] text-[11px] font-bold uppercase tracking-button cursor-pointer transition-all duration-300 inline-flex items-center gap-3 rounded-none hover:scale-105 hover:shadow-lg hover:shadow-[#06B6D4]/50"
					>
						EXPLORE OUR DIGITAL MARKETING SERVICES
						<svg
							width="16"
							height="16"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="3"
								d="M9 5l7 7-7 7"></path>
						</svg>
					</button>
				</div>
			</div>

			<!-- Services Grid -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16">
				<!-- Service 01 -->
				<div
					class="relative pt-12 pb-8 border-t border-black/[0.08] transition-all duration-300 cursor-pointer group hover:bg-black/[0.02] hover:px-6 hover:-mx-6"
				>
					<div
						class="absolute top-12 right-0 text-[18px] font-bold text-[#06B6D4] tracking-[0.1em] group-hover:right-6 transition-all duration-300"
					>
						01
					</div>
					<div
						class="text-black/40 mb-8 transition-colors duration-300 group-hover:text-[#06B6D4]"
					>
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<rect
								x="3"
								y="3"
								width="18"
								height="18"
								rx="2"
								stroke-width="1.5"></rect>
							<path d="M3 9h18M9 21V9" stroke-width="1.5"></path>
						</svg>
					</div>
					<h3
						class="text-[20px] font-bold mb-5 leading-heading transition-colors duration-300 group-hover:text-[#06B6D4]"
					>
						Indoor Billboard Advertising
					</h3>
					<p
						class="py-5 text-[15px] leading-[1.7] text-black/60 transition-colors duration-300 group-hover:text-black/80"
					>
						High-impact advertising in premium indoor locations
						across Denver.
					</p>
				</div>

				<!-- Service 02 -->
				<div
					class="relative pt-12 pb-8 border-t border-black/[0.08] transition-all duration-300 cursor-pointer group hover:bg-black/[0.02] hover:px-6 hover:-mx-6"
				>
					<div
						class="absolute top-12 right-0 text-[18px] font-bold text-[#06B6D4] tracking-[0.1em] group-hover:right-6 transition-all duration-300"
					>
						02
					</div>
					<div
						class="text-black/40 mb-8 transition-colors duration-300 group-hover:text-[#06B6D4]"
					>
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
							></path>
						</svg>
					</div>
					<h3
						class="text-[20px] font-bold mb-5 leading-heading transition-colors duration-300 group-hover:text-[#06B6D4]"
					>
						Social Media Marketing
					</h3>
					<p
						class="py-5 text-[15px] leading-[1.7] text-black/60 transition-colors duration-300 group-hover:text-black/80"
					>
						Build and engage your audience with strategic social
						media content.
					</p>
				</div>

				<!-- Service 03 -->
				<div
					class="relative pt-12 pb-8 border-t border-black/[0.08] transition-all duration-300 cursor-pointer group hover:bg-black/[0.02] hover:px-6 hover:-mx-6"
				>
					<div
						class="absolute top-12 right-0 text-[18px] font-bold text-[#06B6D4] tracking-[0.1em] group-hover:right-6 transition-all duration-300"
					>
						03
					</div>
					<div
						class="text-black/40 mb-8 transition-colors duration-300 group-hover:text-[#06B6D4]"
					>
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<circle cx="12" cy="12" r="10" stroke-width="1.5"
							></circle>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M2 12h20"></path>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"
							></path>
						</svg>
					</div>
					<h3
						class="text-[20px] font-bold mb-5 leading-heading transition-colors duration-300 group-hover:text-[#06B6D4]"
					>
						Custom Website Design
					</h3>
					<p
						class="py-5 text-[15px] leading-[1.7] text-black/60 transition-colors duration-300 group-hover:text-black/80"
					>
						Professional websites that convert visitors into
						customers
					</p>
				</div>

				<!-- Service 04 -->
				<div
					class="relative pt-12 pb-8 border-t border-black/[0.08] transition-all duration-300 cursor-pointer group hover:bg-black/[0.02] hover:px-6 hover:-mx-6"
				>
					<div
						class="absolute top-12 right-0 text-[18px] font-bold text-[#06B6D4] tracking-[0.1em] group-hover:right-6 transition-all duration-300"
					>
						04
					</div>
					<div
						class="text-black/40 mb-8 transition-colors duration-300 group-hover:text-[#06B6D4]"
					>
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<circle cx="12" cy="12" r="3" stroke-width="1.5"
							></circle>
							<circle cx="12" cy="12" r="8" stroke-width="1.5"
							></circle>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M12 2v4m0 12v4M2 12h4m12 0h4"></path>
						</svg>
					</div>
					<h3
						class="text-[20px] font-bold mb-5 leading-heading transition-colors duration-300 group-hover:text-[#06B6D4]"
					>
						Targeted Lead Generation
					</h3>
					<p
						class="py-5 text-[15px] leading-[1.7] text-black/60 transition-colors duration-300 group-hover:text-black/80"
					>
						Strategic campaigns that generate quality leads and
						maximize ROI.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Venue Network Section -->
	<section
		class="bg-black text-white px-8 py-28 border-b border-white/10 max-lg:px-6 max-lg:py-20"
	>
		<div class="max-w-[90rem] mx-auto">
			<div
				class="grid grid-cols-1 lg:grid-cols-2 gap-20 lg:gap-28 items-center"
			>
				<!-- Left: Content -->
				<div>
					<div class="flex items-center gap-4">
						<div class="h-[2px] w-12 bg-[#06B6D4]"></div>

						<span
							class="text-sm font-bold uppercase tracking-[0.2em] text-[#06B6D4]"
						>
							Venue Network
						</span>
					</div>
					<h2
						class="font-display text-[clamp(2.5rem,6vw,4rem)] font-bold leading-display tracking-tighter mb-8"
					>
						Denver's Premium Venue Partner Network
					</h2>
					<p
						class="text-[18px] leading-[1.7] text-white/60 py-5 mb-16 max-w-[500px]"
					>
						Our <span class="font-bold text-[#06B6D4]"
							>digital marketing pros</span
						> have built exclusive partnerships with Denver's most popular
						venues and businesses. Our screen network reaches customers
						when they're relaxed, engaged, and ready to take action—whether
						they're working out, dining, shopping, or waiting for service.
					</p>
					<ul
						class="list-none p-0 m-0 mb-10 grid grid-cols-1 md:grid-cols-2 gap-4"
					>
						<li
							class="flex items-center gap-3.5 text-[14px] font-semibold text-white"
						>
							<svg
								class="text-[#06B6D4] flex-shrink-0"
								width="20"
								height="20"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<circle cx="12" cy="12" r="10" stroke-width="2"
								></circle>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9 12l2 2 4-4"></path>
							</svg>
							<span>Exclusive venue partnerships</span>
						</li>
						<li
							class="flex items-center gap-3.5 text-[14px] font-semibold text-white"
						>
							<svg
								class="text-[#06B6D4] flex-shrink-0"
								width="20"
								height="20"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<circle cx="12" cy="12" r="10" stroke-width="2"
								></circle>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9 12l2 2 4-4"></path>
							</svg>
							<span>High-dwell-time locations</span>
						</li>
						<li
							class="flex items-center gap-3.5 text-[14px] font-semibold text-white"
						>
							<svg
								class="text-[#06B6D4] flex-shrink-0"
								width="20"
								height="20"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<circle cx="12" cy="12" r="10" stroke-width="2"
								></circle>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9 12l2 2 4-4"></path>
							</svg>
							<span>Targeted audience reach</span>
						</li>
						<li
							class="flex items-center gap-3.5 text-[14px] font-semibold text-white"
						>
							<svg
								class="text-[#06B6D4] flex-shrink-0"
								width="20"
								height="20"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<circle cx="12" cy="12" r="10" stroke-width="2"
								></circle>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9 12l2 2 4-4"></path>
							</svg>
							<span>Flexible campaign</span>
						</li>
					</ul>

					<button
						class="bg-transparent text-white border-2 border-white px-8 py-4 text-[11px] font-bold uppercase tracking-button cursor-pointer transition-all duration-300 inline-flex items-center gap-3 rounded-none hover:scale-105 hover:shadow-lg hover:shadow-white/30"
					>
						VIEW ALL VENUES
						<svg
							width="14"
							height="14"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="3"
								d="M9 5l7 7-7 7"></path>
						</svg>
					</button>
				</div>

				<!-- Right: Image with Tags -->
				<div class="relative rounded-none overflow-hidden">
					<img
						src="/venue-partner-mobile.avif"
						alt="Indoor digital advertising screen in retail environment"
						class="w-full h-[500px] max-lg:h-[400px] object-cover block"
						width="800"
						height="500"
						loading="lazy"
						decoding="async"
						fetchpriority="low"
					/>
					<div
						class="absolute bottom-6 left-6 right-6 flex flex-wrap gap-3"
					>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Full Stack Section -->
	<section
		class="bg-[#f9f9f7] px-8 py-28 border-b border-black/[0.08] max-lg:px-6 max-lg:py-20"
	>
		<div class="max-w-[90rem] mx-auto">
			<div
				class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center"
			>
				<!-- Left: Content + Image -->
				<div class="flex flex-col">
					<div class="flex items-center gap-4 mb-6">
						<div class="h-[2px] w-12 bg-[#06B6D4]"></div>

						<span
							class="text-sm font-bold uppercase tracking-[0.2em] text-[#06B6D4]"
						>
							Full Stack
						</span>
					</div>
					<h2
						class="font-display text-[clamp(2.5rem,5vw,3.5rem)] font-bold leading-display tracking-tighter mb-6"
					>
						Full-Service Digital Marketing from Denver Pros
					</h2>
					<p
						class="text-[18px] leading-[1.7] py-5 text-black/60 mb-12"
					>
						Beyond screen ads, our Denver marketing pros provide
						full-scale digital marketing to help your business show
						up, stand out, and grow. Whether you're just getting
						started or need help scaling your outreach, we've got
						the tools and the team to support you.
					</p>

					<!-- Image with Tag -->
					<div class="relative rounded-none overflow-hidden w-full">
						<img
							src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&q=80&auto=format"
							alt="Team collaboration"
							class="w-full h-[280px] object-cover block"
							width="600"
							height="280"
							loading="lazy"
							decoding="async"
							fetchpriority="low"
						/>
						<span
							class="absolute bottom-5 left-5 bg-[#06B6D4] text-black px-5 py-2.5 text-[10px] font-extrabold uppercase tracking-[0.15em] rounded-none"
							>DENVER PROS</span
						>
					</div>
				</div>

				<!-- Right: Services List -->
				<div class="flex flex-col">
					<div class="flex flex-col gap-0">
						<!-- Service 01 -->
						<div
							class="flex gap-6 py-7 border-t border-black/[0.08] items-start transition-all duration-300 cursor-pointer group hover:bg-black/[0.02] hover:px-6 hover:-mx-6"
						>
							<div class="flex-1">
								<div class="flex items-center gap-3 mb-3">
									<div
										class="text-black/40 transition-colors duration-300 group-hover:text-[#06B6D4]"
									>
										<svg
											width="24"
											height="24"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="1.5"
												d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
											></path>
										</svg>
									</div>
									<h3
										class="text-[20px] font-extrabold leading-[1.3] tracking-[-0.01em] transition-colors duration-300 group-hover:text-[#06B6D4]"
									>
										Google Business Profile Setup
									</h3>
								</div>
								<p
									class="text-[15px] leading-[1.7] text-black/60 transition-colors duration-300 group-hover:text-black/80"
								>
									Get found on Google Maps and local search.
								</p>
							</div>
						</div>

						<!-- Service 02 -->
						<div
							class="flex gap-6 py-7 border-t border-black/[0.08] items-start transition-all duration-300 cursor-pointer group hover:bg-black/[0.02] hover:px-6 hover:-mx-6"
						>
							<div class="flex-1">
								<div class="flex items-center gap-3 mb-3">
									<div
										class="text-black/40 transition-colors duration-300 group-hover:text-[#06B6D4]"
									>
										<svg
											width="24"
											height="24"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24"
										>
											<circle
												cx="12"
												cy="12"
												r="10"
												stroke-width="1.5"></circle>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="1.5"
												d="M2 12h20"></path>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="1.5"
												d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"
											></path>
										</svg>
									</div>
									<h3
										class="text-[20px] font-extrabold leading-[1.3] tracking-[-0.01em] transition-colors duration-300 group-hover:text-[#06B6D4]"
									>
										Professional Website Design
									</h3>
								</div>
								<p
									class="text-[15px] leading-[1.7] text-black/60 transition-colors duration-300 group-hover:text-black/80"
								>
									Fast, mobile-ready websites built for
									performance.
								</p>
							</div>
						</div>

						<!-- Service 03 -->
						<div
							class="flex gap-6 py-7 border-t border-black/[0.08] items-start transition-all duration-300 cursor-pointer group hover:bg-black/[0.02] hover:px-6 hover:-mx-6"
						>
