---
import Layout from "../layouts/Layout.astro";
import { getImage } from "astro:assets";
import homeImage from "../assets/home.avif";
import { Image } from "astro:assets";
import section3Image from "../assets/venue-partner-mobile.avif";

const optimizedBackground = await getImage({ src: homeImage });
---

<Layout title="NTV Template 5 Clone">
	<!-- Hero Section - Refined & Responsive -->
	<section
		class="relative min-h-screen flex items-center justify-center pt-20 md:pt-24 lg:pt-28 pb-12 md:pb-16 lg:pb-20 px-4 md:px-6 bg-gradient-to-br from-[#0a1628] via-[#0d1f3c] to-[#0a1628]"
	>
		<!-- Background Image - Better Positioned -->
		<div class="absolute inset-0 overflow-hidden">
			<div
				class="absolute inset-0 w-full h-full bg-cover bg-center opacity-50"
				style={`background-image: url(${optimizedBackground.src}); background-position: center 40%;`}
			>
			</div>
			<!-- Gradient Overlay for Better Text Visibility -->
			<div
				class="absolute inset-0 bg-gradient-to-r from-[#0a1628]/90 via-[#0a1628]/70 to-[#0a1628]/90"
			>
			</div>
			<div
				class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#0a1628]/80"
			>
			</div>
		</div>

		<div class="relative z-10 w-full max-w-7xl mx-auto">
			<div class="text-center max-w-4xl mx-auto space-y-6 md:space-y-8">
				<!-- Badge -->
				<div class="flex justify-center">
					<div
						class="inline-flex items-center gap-2 bg-blue-500/10 border border-blue-400/30 rounded-full px-3 py-2 md:px-5 md:py-2.5 backdrop-blur-sm"
					>
						<svg
							class="w-3 h-3 md:w-4 md:h-4 text-blue-400"
							fill="currentColor"
							viewBox="0 0 20 20"
						>
							<path
								d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"
							></path>
							<path
								d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"
							></path>
						</svg>
						<span
							class="text-blue-300 text-xs md:text-sm font-semibold tracking-wider uppercase"
							>Premium Marketing Solutions</span
						>
					</div>
				</div>

				<!-- Main Heading - Responsive Size -->
				<h1
					class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-[1.1] tracking-tight px-2"
				>
					Local Advertising and
					<span
						class="block text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-cyan-300 to-blue-400 mt-2"
					>
						Digital Marketing
					</span>
					<span class="block mt-2">Pros in Denver</span>
				</h1>

				<!-- Subheading -->
				<div class="flex justify-center px-4">
					<div
						class="flex items-start gap-2 md:gap-3 bg-white/5 backdrop-blur-sm border border-white/10 rounded-lg md:rounded-xl p-4 md:p-5 max-w-xl"
					>
						<svg
							class="w-5 h-5 md:w-6 md:h-6 text-blue-400 shrink-0 mt-0.5"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
						</svg>
						<p
							class="text-blue-300 text-base md:text-lg leading-relaxed text-left"
						>
							Helping Businesses Get Noticed—On Screens and Online
						</p>
					</div>
				</div>

				<!-- CTA Buttons -->
				<div
					class="flex flex-col sm:flex-row flex-wrap justify-center gap-3 md:gap-4 pt-2 md:pt-4 px-4"
				>
					<button
						class="bg-white text-[#0a1628] px-8 md:px-10 py-3 md:py-4 rounded-lg font-semibold hover:bg-blue-50 transition-all uppercase tracking-wide text-sm shadow-2xl hover:shadow-blue-500/20 hover:scale-105 transform duration-200"
					>
						Talk to Our Team
					</button>
					<button
						class="bg-transparent border-2 border-white/40 text-white px-8 md:px-10 py-3 md:py-4 rounded-lg font-semibold hover:bg-white/10 hover:border-white/60 transition-all uppercase tracking-wide text-sm backdrop-blur-sm"
					>
						Learn More
					</button>
				</div>
			</div>
		</div>

		<!-- Bottom Gradient Fade -->
		<div
			class="absolute bottom-0 left-0 right-0 h-24 md:h-32 bg-gradient-to-t from-white to-transparent"
		>
		</div>
	</section>

	<!-- Content Section -->
	<section class="bg-white py-12 md:py-16 lg:py-20">
		<div class="max-w-7xl mx-auto px-4 md:px-6">
			<div
				class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 md:gap-8 mb-12 md:mb-16 lg:mb-20"
			>
				<div class="lg:flex-1 lg:max-w-3xl">
					<h2 class="mb-4 md:mb-6">
						Local Advertising Solutions for Denver Businesses
					</h2>
					<p>
						As your trusted <span
							class="font-semibold text-gray-900"
							>Denver marketing pros</span
						>, our
						<a href="#" class="text-blue-600 hover:underline"
							>billboard network</a
						> to high-traffic locations where your ideal customers spend
						time. From gyms and restaurants to retail stores and office
						buildings, we help you get noticed in the moments that matter.
					</p>
				</div>

				<div class="lg:flex-shrink-0 lg:self-end">
					<button
						class="bg-blue-900 text-white px-6 md:px-8 py-3 md:py-4 rounded-lg font-semibold hover:bg-blue-800 transition-colors flex items-center justify-center text-sm shadow-lg w-full lg:w-auto"
					>
						<svg
							class="w-4 h-4 md:w-5 md:h-5 mr-2 flex-shrink-0"
							fill="currentColor"
							viewBox="0 0 20 20"
						>
							<path
								d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"
							></path>
						</svg>
						<span class="uppercase tracking-wide leading-tight"
							>Explore Our Digital Marketing Services</span
						>
					</button>
				</div>
			</div>

			<!-- Services Grid -->
			<div class="grid md:grid-cols-2 gap-4 md:gap-6 lg:gap-8">
				<!-- Indoor Billboard Advertising -->
				<div
					class="bg-white border border-gray-200 rounded-xl md:rounded-2xl p-5 md:p-6 lg:p-8 hover:shadow-xl transition-all duration-300 hover:border-blue-300"
				>
					<div class="flex items-start gap-4 md:gap-6">
						<div class="shrink-0">
							<div
								class="w-12 h-12 md:w-14 md:h-14 lg:w-16 lg:h-16 bg-blue-50 rounded-lg md:rounded-xl flex items-center justify-center"
							>
								<svg
									class="w-6 h-6 md:w-7 md:h-7 lg:w-8 lg:h-8 text-blue-600"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<rect
										x="3"
										y="3"
										width="18"
										height="18"
										rx="2"
										stroke-width="2"></rect>
									<path
										d="M9 9h6M9 12h6M9 15h4"
										stroke-width="2"
										stroke-linecap="round"></path>
								</svg>
							</div>
						</div>
						<div class="flex-1 min-w-0">
							<h3
								class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
							>
								Indoor Billboard Advertising
							</h3>
							<p
								class="text-sm md:text-base text-gray-600 leading-relaxed"
							>
								High-impact advertising in premium indoor
								locations across Denver
							</p>
						</div>
					</div>
				</div>

				<!-- Social Media Marketing -->
				<div
					class="bg-white border border-gray-200 rounded-xl md:rounded-2xl p-5 md:p-6 lg:p-8 hover:shadow-xl transition-all duration-300 hover:border-blue-300"
				>
					<div class="flex items-start gap-4 md:gap-6">
						<div class="shrink-0">
							<div
								class="w-12 h-12 md:w-14 md:h-14 lg:w-16 lg:h-16 bg-blue-50 rounded-lg md:rounded-xl flex items-center justify-center"
							>
								<svg
									class="w-6 h-6 md:w-7 md:h-7 lg:w-8 lg:h-8 text-blue-600"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"></path>
								</svg>
							</div>
						</div>
						<div class="flex-1 min-w-0">
							<h3
								class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
							>
								Social Media Marketing
							</h3>
							<p
								class="text-sm md:text-base text-gray-600 leading-relaxed"
							>
								Build and engage your audience with strategic
								social media content
							</p>
						</div>
					</div>
				</div>

				<!-- Custom Website Design -->
				<div
					class="bg-white border border-gray-200 rounded-xl md:rounded-2xl p-5 md:p-6 lg:p-8 hover:shadow-xl transition-all duration-300 hover:border-blue-300"
				>
					<div class="flex items-start gap-4 md:gap-6">
						<div class="shrink-0">
							<div
								class="w-12 h-12 md:w-14 md:h-14 lg:w-16 lg:h-16 bg-blue-50 rounded-lg md:rounded-xl flex items-center justify-center"
							>
								<svg
									class="w-6 h-6 md:w-7 md:h-7 lg:w-8 lg:h-8 text-blue-600"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"></path>
								</svg>
							</div>
						</div>
						<div class="flex-1 min-w-0">
							<h3
								class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
							>
								Custom Website Design
							</h3>
							<p
								class="text-sm md:text-base text-gray-600 leading-relaxed"
							>
								Professional websites that convert visitors into
								customers
							</p>
						</div>
					</div>
				</div>

				<!-- Targeted Lead Generation -->
				<div
					class="bg-white border border-gray-200 rounded-xl md:rounded-2xl p-5 md:p-6 lg:p-8 hover:shadow-xl transition-all duration-300 hover:border-blue-300"
				>
					<div class="flex items-start gap-4 md:gap-6">
						<div class="shrink-0">
							<div
								class="w-12 h-12 md:w-14 md:h-14 lg:w-16 lg:h-16 bg-blue-50 rounded-lg md:rounded-xl flex items-center justify-center"
							>
								<svg
									class="w-6 h-6 md:w-7 md:h-7 lg:w-8 lg:h-8 text-blue-600"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"></path>
									<path
										d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"></path>
								</svg>
							</div>
						</div>
						<div class="flex-1 min-w-0">
							<h3
								class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
							>
								Targeted Lead Generation
							</h3>
							<p
								class="text-sm md:text-base text-gray-600 leading-relaxed"
							>
								Strategic campaigns that generate quality leads
								and maximize ROI
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Venue Partner Network Section -->
	<section
		class="bg-gradient-to-br from-slate-50 to-blue-50 py-12 md:py-16 lg:py-20"
	>
		<div class="max-w-7xl mx-auto px-4 md:px-6">
			<div
				class="grid lg:grid-cols-2 gap-8 md:gap-12 lg:gap-16 items-center"
			>
				<!-- Content Side -->
				<div class="order-2 lg:order-1">
					<h2 class="mb-4 md:mb-6">
						Denver's Premier Venue Partner Network
					</h2>
					<p class="mb-6 md:mb-8">
						Our <span class="font-semibold text-gray-900"
							>digital marketing pros</span
						> have built exclusive partnerships with Denver's most popular
						venues and businesses. Our <span
							class="font-semibold text-gray-900"
							>screen network</span
						> reaches customers when they're relaxed, engaged, and ready
						to take action—whether they're working out, dining, shopping,
						or waiting for service.
					</p>

					<!-- Features List -->
					<ul class="space-y-3 md:space-y-4 mb-6 md:mb-8">
						<li class="flex items-start gap-3">
							<svg
								class="w-5 h-5 md:w-6 md:h-6 text-blue-600 shrink-0 mt-0.5"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M5 13l4 4L19 7"></path>
							</svg>
							<span class="text-gray-700 text-sm md:text-base"
								>Exclusive venue partnerships</span
							>
						</li>
						<li class="flex items-start gap-3">
							<svg
								class="w-5 h-5 md:w-6 md:h-6 text-blue-600 shrink-0 mt-0.5"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M5 13l4 4L19 7"></path>
							</svg>
							<span class="text-gray-700 text-sm md:text-base"
								>High-dwell-time locations</span
							>
						</li>
						<li class="flex items-start gap-3">
							<svg
								class="w-5 h-5 md:w-6 md:h-6 text-blue-600 shrink-0 mt-0.5"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M5 13l4 4L19 7"></path>
							</svg>
							<span class="text-gray-700 text-sm md:text-base"
								>Targeted audience reach</span
							>
						</li>
						<li class="flex items-start gap-3">
							<svg
								class="w-5 h-5 md:w-6 md:h-6 text-blue-600 shrink-0 mt-0.5"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M5 13l4 4L19 7"></path>
							</svg>
							<span class="text-gray-700 text-sm md:text-base"
								>Flexible campaign options</span
							>
						</li>
					</ul>

					<button
						class="bg-white border-2 border-blue-900 text-blue-900 px-6 md:px-8 py-3 md:py-4 rounded-lg font-semibold hover:bg-blue-900 hover:text-white transition-all shadow-md hover:shadow-lg uppercase tracking-wide text-sm"
					>
						View Venue Partners
					</button>
				</div>

				<!-- Image Side -->
				<div class="order-1 lg:order-2">
					<div
						class="relative rounded-2xl overflow-hidden shadow-2xl"
					>
						<Image
							src={section3Image}
							alt="Digital billboard in venue"
							class="w-full h-auto object-cover"
						/>
						<div
							class="absolute inset-0 bg-gradient-to-t from-blue-900/20 to-transparent"
						>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
