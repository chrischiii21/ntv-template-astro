---
import Layout from "../layouts/Layout.astro";
import { getImage } from "astro:assets";
import homeImage from "../assets/home.avif";
import { Image } from "astro:assets";
import section3Image from "../assets/venue-partner-mobile.avif";
import Footer from "../components/Footer.astro";
import Map from "../components/Map.astro";

const optimizedBackground = await getImage({ src: homeImage });
---

<Layout title="NTV Template 5 Clone">
	<!-- Hero Section - Balanced & Clean -->
	<section
		class="relative flex items-center justify-center pt-32 md:pt-40 lg:pt-44 pb-20 md:pb-24 lg:pb-28 px-4 md:px-6 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900"
	>
		<!-- Background Image -->
		<div class="absolute inset-0 overflow-hidden">
			<div
				class="absolute inset-0 w-full h-full bg-cover bg-center opacity-40"
				style={`background-image: url(${optimizedBackground.src}); background-position: center 40%;`}
			>
			</div>
			<!-- Simplified Overlay -->
			<div
				class="absolute inset-0 bg-gradient-to-b from-slate-900/85 via-slate-900/75 to-slate-900/90"
			>
			</div>
		</div>

		<div class="relative z-10 w-full max-w-6xl mx-auto">
			<div class="text-center max-w-4xl mx-auto space-y-5 md:space-y-6">
				<!-- Badge -->
				<div class="flex justify-center">
					<div
						class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-400/30 rounded-full px-4 py-2 backdrop-blur-sm"
					>
						<svg
							class="w-3.5 h-3.5 text-sky-400"
							fill="currentColor"
							viewBox="0 0 20 20"
						>
							<path
								d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"
							></path>
							<path
								d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"
							></path>
						</svg>
						<span
							class="text-sky-300 text-xs md:text-sm font-semibold tracking-wider uppercase"
							>Premium Marketing Solutions</span
						>
					</div>
				</div>

				<!-- Main Heading -->
				<h1
					class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-tight tracking-tight px-2"
				>
					Local Advertising and
					<span
						class="block text-transparent bg-clip-text bg-gradient-to-r from-sky-400 via-indigo-300 to-sky-400 mt-1.5"
					>
						Digital Marketing
					</span>
					<span class="block mt-1.5">Pros in Denver</span>
				</h1>

				<!-- Subheading - Simplified -->
				<p
					class="text-sky-200 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto px-4"
				>
					Helping Businesses Get Noticed—On Screens and Online
				</p>

				<!-- CTA Buttons -->
				<div
					class="flex flex-col sm:flex-row justify-center gap-3 md:gap-4 pt-3 px-4"
				>
					<button
						class="bg-white text-slate-900 px-8 py-3.5 rounded-lg font-semibold hover:bg-slate-50 transition-all uppercase tracking-wide text-sm shadow-xl hover:shadow-indigo-500/20 hover:scale-105 transform duration-200"
					>
						Talk to Our Team
					</button>
					<button
						class="bg-transparent border-2 border-white/40 text-white px-8 py-3.5 rounded-lg font-semibold hover:bg-white/10 hover:border-white/60 transition-all uppercase tracking-wide text-sm backdrop-blur-sm"
					>
						Learn More
					</button>
				</div>
			</div>
		</div>

		<!-- Bottom Gradient Fade -->
		<div
			class="absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-white to-transparent"
		>
		</div>
	</section>

	<!-- Services Section -->
	<section class="bg-slate-50 py-16 md:py-20 lg:py-24">
		<div class="max-w-7xl mx-auto px-4 md:px-6">
			<!-- Section Header -->
			<div class="text-center mb-10 md:mb-12 max-w-3xl mx-auto">
				<h2
					class="text-3xl md:text-4xl lg:text-5xl font-bold text-slate-900 mb-4"
				>
					Local Advertising Solutions for Denver Businesses
				</h2>
				<p class="text-slate-600 text-base md:text-lg leading-relaxed">
					As your trusted <span class="font-bold text-slate-900"
						>Denver marketing pros</span
					>, our <span class="text-indigo-600 font-semibold"
						>billboard network</span
					> gives you access to high-traffic locations where your ideal
					customers spend time. From gyms and restaurants to retail stores
					and office buildings, we help you get noticed in the moments that
					matter.
				</p>
			</div>
			<!-- Unique Asymmetric Grid Layout -->
			<div class="grid lg:grid-cols-2 gap-6 md:gap-7">
				<!-- Featured Card - Indoor Billboard (Large) -->
				<div
					class="group bg-gradient-to-br from-slate-800 to-slate-900 rounded-2xl p-8 md:p-10 lg:p-12 hover:shadow-2xl transition-all duration-300 lg:row-span-2 flex flex-col justify-between"
				>
					<div>
						<h3
							class="text-2xl md:text-3xl lg:text-4xl font-bold text-white mb-4 uppercase tracking-wide"
						>
							Local Advertising Solutions for Denver Businesses
						</h3>
						<p
							class="text-slate-300 text-base md:text-lg leading-relaxed mb-6"
						>
							As your trusted <span class="font-bold text-white"
								>Denver marketing pros</span
							>, our <span class="text-indigo-400 font-semibold"
								>billboard network</span
							> gives you access to high-traffic locations where your
							ideal customers spend time. From gyms and restaurants
							to retail stores and office buildings, we help you get
							noticed in the moments that matter.
						</p>
					</div>
					<div
						class="flex items-center gap-2 text-indigo-400 font-semibold group-hover:gap-3 transition-all group-hover:text-indigo-300"
					>
						<span class="text-sm uppercase tracking-wider"
							>Explore Our Digital Marketing Services</span
						>
						<svg
							class="w-5 h-5"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
						</svg>
					</div>
				</div>

				<!-- Compact Cards Column -->
				<div class="space-y-6 md:space-y-7">
					<!-- Indoor Billboard Advertising Card -->
					<div
						class="group bg-slate-50 rounded-2xl p-6 hover:shadow-xl transition-all duration-300 border-2 border-slate-200 hover:border-indigo-400"
					>
						<div class="flex items-start gap-4">
							<div
								class="w-12 h-12 bg-indigo-600 rounded-xl flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform"
							>
								<svg
									class="w-8 h-8 text-white"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<rect
										x="3"
										y="3"
										width="18"
										height="18"
										rx="2"
										stroke-width="2"></rect>
									<path
										d="M9 9h6M9 12h6M9 15h4"
										stroke-width="2"
										stroke-linecap="round"></path>
								</svg>
							</div>
							<div>
								<h3
									class="text-lg md:text-xl font-bold text-slate-900 mb-2 uppercase tracking-wide"
								>
									Indoor Billboard Advertising
								</h3>
								<p
									class="text-slate-700 text-sm leading-relaxed"
								>
									High-impact advertising in premium indoor
									locations across Denver. Reach your audience
									where they spend their time.
								</p>
							</div>
						</div>
					</div>
					<!-- Social Media Marketing Card -->
					<div
						class="group bg-slate-50 rounded-2xl p-6 hover:shadow-xl transition-all duration-300 border-2 border-slate-200 hover:border-indigo-400"
					>
						<div class="flex items-start gap-4">
							<div
								class="w-12 h-12 bg-indigo-600 rounded-xl flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform"
							>
								<svg
									class="w-6 h-6 text-white"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
									></path>
								</svg>
							</div>
							<div>
								<h3
									class="text-lg md:text-xl font-bold text-slate-900 mb-2 uppercase tracking-wide"
								>
									Social Media Marketing
								</h3>
								<p
									class="text-slate-700 text-sm leading-relaxed"
								>
									Build and engage your audience with
									strategic social media content
								</p>
							</div>
						</div>
					</div>

					<!-- Custom Website Design Card -->
					<div
						class="group bg-slate-50 rounded-2xl p-6 hover:shadow-xl transition-all duration-300 border-2 border-slate-200 hover:border-sky-400"
					>
						<div class="flex items-start gap-4">
							<div
								class="w-12 h-12 bg-sky-500 rounded-xl flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform"
							>
								<svg
									class="w-6 h-6 text-white"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
									></path>
								</svg>
							</div>
							<div>
								<h3
									class="text-lg md:text-xl font-bold text-slate-900 mb-2 uppercase tracking-wide"
								>
									Custom Website Design
								</h3>
								<p
									class="text-slate-700 text-sm leading-relaxed"
								>
									Professional websites that convert visitors
									into customers
								</p>
							</div>
						</div>
					</div>

					<!-- Targeted Lead Generation Card -->
					<div
						class="group bg-slate-50 rounded-2xl p-6 hover:shadow-xl transition-all duration-300 border-2 border-slate-200 hover:border-indigo-400"
					>
						<div class="flex items-start gap-4">
							<div
								class="w-12 h-12 bg-indigo-600 rounded-xl flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform"
							>
								<svg
									class="w-6 h-6 text-white"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
									></path>
								</svg>
							</div>
							<div>
								<h3
									class="text-lg md:text-xl font-bold text-slate-900 mb-2 uppercase tracking-wide"
								>
									Targeted Lead Generation
								</h3>
								<p
									class="text-slate-700 text-sm leading-relaxed"
								>
									Strategic campaigns that generate quality
									leads and maximize ROI
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Venue Partner Network Section - Balanced & Clean -->
	<section class="relative bg-white py-16 md:py-20 lg:py-24 overflow-hidden">
		<div class="max-w-6xl mx-auto px-4 md:px-6">
			<!-- Section Header -->
			<div class="text-center mb-10 md:mb-12">
				<h2
					class="text-3xl md:text-4xl lg:text-5xl font-bold text-slate-900 mb-3"
				>
					Denver's Premier Venue Partner Network
				</h2>
				<p
					class="text-base md:text-lg text-slate-600 max-w-2xl mx-auto"
				>
					Exclusive partnerships with Denver's most popular venues
					reaching customers when they're engaged and ready to take
					action.
				</p>
			</div>

			<!-- Content Grid -->
			<div class="grid lg:grid-cols-2 gap-8 md:gap-10 items-start">
				<!-- Image Side with Stats -->
				<div class="relative order-2 lg:order-1">
					<div
						class="relative rounded-xl overflow-hidden shadow-xl aspect-[5/4]"
					>
						<img
							src="https://images.unsplash.com/photo-1556761175-b413da4baf72?w=800&q=80"
							alt="Modern digital advertising display"
							class="w-full h-full object-cover"
						/>
						<div
							class="absolute inset-0 bg-gradient-to-t from-slate-900/50 to-transparent"
						>
						</div>

						<!-- Stats Overlay -->
						<div
							class="absolute bottom-3 left-3 right-3 grid grid-cols-2 gap-2.5"
						>
							<div
								class="bg-white/95 backdrop-blur-sm rounded-lg p-3.5"
							>
								<div
									class="text-2xl md:text-3xl font-bold text-indigo-600"
								>
									50+
								</div>
								<div class="text-xs text-slate-600 font-medium">
									Premium Venues
								</div>
							</div>
							<div
								class="bg-white/95 backdrop-blur-sm rounded-lg p-3.5"
							>
								<div
									class="text-2xl md:text-3xl font-bold text-indigo-600"
								>
									2M+
								</div>
								<div class="text-xs text-slate-600 font-medium">
									Monthly Views
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Content Side -->
				<div class="order-1 lg:order-2">
					<!-- Benefits Grid -->
					<div class="grid gap-3.5 mb-6">
						<div
							class="flex items-start gap-3 bg-white rounded-lg p-4 border border-slate-200 hover:border-indigo-200 transition-colors"
						>
							<div
								class="w-9 h-9 bg-indigo-100 rounded-lg flex items-center justify-center shrink-0"
							>
								<svg
									class="w-5 h-5 text-indigo-600"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
							</div>
							<div>
								<h4
									class="font-semibold text-slate-900 text-sm mb-1"
								>
									Local Market Expertise
								</h4>
								<p
									class="text-xs text-slate-600 leading-relaxed"
								>
									Strategic placement in high-traffic Denver
									locations
								</p>
							</div>
						</div>

						<div
							class="flex items-start gap-3 bg-white rounded-lg p-4 border border-slate-200 hover:border-sky-200 transition-colors"
						>
							<div
								class="w-9 h-9 bg-sky-100 rounded-lg flex items-center justify-center shrink-0"
							>
								<svg
									class="w-5 h-5 text-sky-600"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
							</div>
							<div>
								<h4
									class="font-semibold text-slate-900 text-sm mb-1"
								>
									High-Dwell-Time Locations
								</h4>
								<p
									class="text-xs text-slate-600 leading-relaxed"
								>
									Gyms, restaurants, retail stores, and office
									buildings
								</p>
							</div>
						</div>

						<div
							class="flex items-start gap-3 bg-white rounded-lg p-4 border border-slate-200 hover:border-indigo-200 transition-colors"
						>
							<div
								class="w-9 h-9 bg-indigo-100 rounded-lg flex items-center justify-center shrink-0"
							>
								<svg
									class="w-5 h-5 text-indigo-600"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
							</div>
							<div>
								<h4
									class="font-semibold text-slate-900 text-sm mb-1"
								>
									Targeted Audience Reach
								</h4>
								<p
									class="text-xs text-slate-600 leading-relaxed"
								>
									Connect with your ideal customers at the
									right moment
								</p>
							</div>
						</div>

						<div
							class="flex items-start gap-3 bg-white rounded-lg p-4 border border-slate-200 hover:border-sky-200 transition-colors"
						>
							<div
								class="w-9 h-9 bg-sky-100 rounded-lg flex items-center justify-center shrink-0"
							>
								<svg
									class="w-5 h-5 text-sky-600"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
							</div>
							<div>
								<h4
									class="font-semibold text-slate-900 text-sm mb-1"
								>
									Flexible Campaign Options
								</h4>
								<p
									class="text-xs text-slate-600 leading-relaxed"
								>
									Customizable solutions to fit your budget
									and goals
								</p>
							</div>
						</div>
					</div>

					<!-- CTA Button -->
					<button
						class="w-full sm:w-auto bg-slate-900 hover:bg-slate-800 text-white px-7 py-3 rounded-lg font-semibold transition-all shadow-lg hover:shadow-xl inline-flex items-center justify-center gap-2"
					>
						View Venue Partners
						<svg
							class="w-5 h-5"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
						</svg>
					</button>
				</div>
			</div>
		</div>
	</section>

	<!-- Full-Service Marketing Section -->
	<section class="bg-slate-50 py-12 md:py-16 lg:py-20">
		<div class="max-w-7xl mx-auto px-4 md:px-6">
			<!-- Section Header -->
			<div class="max-w-4xl mb-12 md:mb-16">
				<div
					class="inline-flex items-center gap-2 border-2 border-slate-900 text-slate-900 text-xs font-bold uppercase tracking-wider px-4 py-2 rounded-lg mb-6"
				>
					<svg
						class="w-4 h-4"
						fill="currentColor"
						viewBox="0 0 20 20"
					>
						<path
							fill-rule="evenodd"
							d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
							clip-rule="evenodd"></path>
					</svg>
					Featured
				</div>
				<h2
					class="text-3xl md:text-4xl lg:text-5xl font-bold text-slate-900 mb-4 md:mb-6"
				>
					Full-Service Digital Marketing from Denver Pros
				</h2>
				<p class="text-slate-600 text-base md:text-lg leading-relaxed">
					Beyond screen ads, our <span
						class="font-semibold text-slate-900"
						>Denver marketing pros</span
					> provide full-scale digital marketing to help your business show
					up, stand out, and grow. Whether you're just getting started or
					need help scaling your outreach, we've got the tools and the team
					to support you.
				</p>
			</div>

			<!-- Hero Image -->
			<div class="mb-12 md:mb-16">
				<div class="relative rounded-3xl overflow-hidden shadow-2xl">
					<img
						src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=1200&q=80"
						alt="Marketing team collaboration"
						class="w-full h-[300px] md:h-[400px] object-cover"
					/>
					<div
						class="absolute inset-0 bg-gradient-to-t from-gray-900/40 to-transparent"
					>
					</div>
				</div>
			</div>

			<!-- Services Grid -->
			<div class="grid md:grid-cols-2 gap-6 md:gap-8 mb-12">
				<!-- Google Business Profile Setup -->
				<div
