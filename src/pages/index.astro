					<script>
						function setActiveLocation(clickedButton) {
							// Remove active state from all buttons
							const allButtons =
								document.querySelectorAll(".location-btn");
							allButtons.forEach((button) => {
								button.classList.remove(
									"bg-slate-900",
									"border-slate-900",
								);
								button.classList.add(
									"bg-white",
									"border-slate-200",
								);

								// Reset icon background
								const iconDiv =
									button.querySelector("div > div");
								iconDiv.classList.remove("bg-white");
								iconDiv.classList.add("bg-slate-100");

								// Reset icon color
								const icon = iconDiv.querySelector("svg");
								icon.classList.remove("text-slate-900");
								icon.classList.add("text-slate-600");

								// Reset text color
								const span = button.querySelector("span");
								span.classList.remove("text-white");
								span.classList.add("text-slate-900");

								// Reset arrow color
								const arrow = button.querySelector("div + svg");
								arrow.classList.remove("text-white");
								arrow.classList.add("text-slate-400");
							});

							// Add active state to clicked button
							clickedButton.classList.remove(
								"bg-white",
								"border-slate-200",
							);
							clickedButton.classList.add(
								"bg-slate-900",
								"border-slate-900",
							);

							// Update icon background
							const iconDiv =
								clickedButton.querySelector("div > div");
							iconDiv.classList.remove("bg-slate-100");
							iconDiv.classList.add("bg-white");

							// Update icon color
							const icon = iconDiv.querySelector("svg");
							icon.classList.remove("text-slate-600");
							icon.classList.add("text-slate-900");

							// Update text color
							const span = clickedButton.querySelector("span");
							span.classList.remove("text-slate-900");
							span.classList.add("text-white");

							// Update arrow color
							const arrow =
								clickedButton.querySelector("div + svg");
							arrow.classList.remove("text-slate-400");
							arrow.classList.add("text-white");

							// Show active indicator (add green dot)
							const activeIconDiv =
								clickedButton.querySelector("div > div");
							activeIconDiv.style.position = "relative";
							let indicator =
								activeIconDiv.querySelector(".active-dot");
							if (!indicator) {
								indicator = document.createElement("span");
								indicator.className =
									"active-dot absolute -top-1 -right-1 w-3 h-3 bg-green-500 rounded-full border-2 border-white";
								activeIconDiv.appendChild(indicator);
							}

							// Hide indicators from other buttons
							allButtons.forEach((button) => {
								if (button !== clickedButton) {
									const dot =
										button.querySelector(".active-dot");
									if (dot) dot.remove();
								}
							});
						}
					</script>

