---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Map from "../components/Map.astro";
---

<Layout title="NTV Pulse Clone - Denver Marketing">
	<!-- Hero Section -->
	<section class="hero-section">
		<div class="hero-pattern"></div>

		<div class="hero-container">
			<div class="hero-label">
				<span>PREMIUM MARKETING</span>
				<span class="separator">·</span>
				<span>DENVER, CO</span>
			</div>

			<h1 class="hero-heading">
				<span class="hero-heading-line">GET YOUR</span>
				<span class="hero-heading-line hero-heading-accent"
					>BUSINESS</span
				>
				<span class="hero-heading-line">NOTICED.</span>
			</h1>

			<p class="hero-description">
				Denver's sharpest advertising and digital marketing<br />
				team — on screens, on search, and everywhere<br />
				your customers are.
			</p>

			<button class="hero-cta">
				TALK TO OUR TEAM
				<svg
					width="16"
					height="16"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="3"
						d="M9 5l7 7-7 7"></path>
				</svg>
			</button>

			<div class="hero-stats">
				<div class="hero-stat">
					<div class="hero-stat-number">500+</div>
					<div class="hero-stat-label">Screens Deployed</div>
				</div>
				<div class="hero-stat">
					<div class="hero-stat-number">20+</div>
					<div class="hero-stat-label">Years of Expertise</div>
				</div>
				<div class="hero-stat">
					<div class="hero-stat-number">1,200+</div>
					<div class="hero-stat-label">Clients Served</div>
				</div>
				<button class="hero-scroll">
					SCROLL
					<svg
						width="12"
						height="12"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="3"
							d="M19 9l-7 7-7-7"></path>
					</svg>
				</button>
			</div>
		</div>
	</section>

	<!-- Services Section -->
	<section class="services-section">
		<div class="services-container">
			<!-- Header with split layout -->
			<div class="services-header">
				<div class="services-header-left">
					<span class="services-label">WHAT WE DO</span>
					<h2 class="services-title">
						<span class="services-title-main"
							>Local Advertising</span
						>
						<span class="services-title-sub">Built for Denver.</span
						>
					</h2>
				</div>
				<div class="services-header-right">
					<p class="services-description">
						From billboard access to full digital campaigns —
						everything your business needs to stand out and scale up
						in the Denver market.
					</p>
				</div>
			</div>

			<!-- Services Grid -->
			<div class="services-grid">
				<!-- Service 01 -->
				<div class="service-card">
					<div class="service-number">01</div>
					<div class="service-icon">
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<rect
								x="3"
								y="3"
								width="18"
								height="18"
								rx="2"
								stroke-width="1.5"></rect>
							<path d="M3 9h18M9 21V9" stroke-width="1.5"></path>
						</svg>
					</div>
					<h3 class="service-card-title">
						Indoor Billboard Advertising
					</h3>
					<p class="service-card-description">
						Own the room. High-impact digital screens placed inside
						Denver's busiest gyms, restaurants, and retail spaces.
					</p>
				</div>

				<!-- Service 02 -->
				<div class="service-card">
					<div class="service-number">02</div>
					<div class="service-icon">
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
							></path>
						</svg>
					</div>
					<h3 class="service-card-title">Social Media Marketing</h3>
					<p class="service-card-description">
						Scroll-stopping content that builds communities and
						turns followers into paying customers.
					</p>
				</div>

				<!-- Service 03 -->
				<div class="service-card">
					<div class="service-number">03</div>
					<div class="service-icon">
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<circle cx="12" cy="12" r="10" stroke-width="1.5"
							></circle>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M2 12h20"></path>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"
							></path>
						</svg>
					</div>
					<h3 class="service-card-title">Custom Website Design</h3>
					<p class="service-card-description">
						Blazing-fast, beautifully-crafted websites engineered to
						convert visitors into loyal clients.
					</p>
				</div>

				<!-- Service 04 -->
				<div class="service-card">
					<div class="service-number">04</div>
					<div class="service-icon">
						<svg
							width="32"
							height="32"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<circle cx="12" cy="12" r="3" stroke-width="1.5"
							></circle>
							<circle cx="12" cy="12" r="8" stroke-width="1.5"
							></circle>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.5"
								d="M12 2v4m0 12v4M2 12h4m12 0h4"></path>
						</svg>
					</div>
					<h3 class="service-card-title">Targeted Lead Generation</h3>
					<p class="service-card-description">
						Precision-targeted campaigns across Google and social
						that hit your pipeline with quality leads.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Venue Network Section -->
	<section class="venue-section">
		<div class="venue-container">
			<div class="venue-grid">
				<!-- Left: Content -->
				<div class="venue-content">
					<span class="venue-label">VENUE NETWORK</span>
					<h2 class="venue-title">
						Denver's Most<br />Coveted Locations.
					</h2>
					<p class="venue-description">
						We've built an exclusive network inside Denver's
						highest-traffic venues — where your audience is already
						present, relaxed, and receptive.
					</p>

					<!-- Stats -->
					<div class="venue-stats">
						<div class="venue-stat">
							<div class="venue-stat-number">80+</div>
							<div class="venue-stat-label">Active Venues</div>
						</div>
						<div class="venue-stat">
							<div class="venue-stat-number">2.4M</div>
							<div class="venue-stat-label">
								Monthly Impressions
							</div>
						</div>
						<div class="venue-stat">
							<div class="venue-stat-number">15+</div>
							<div class="venue-stat-label">Neighborhoods</div>
						</div>
					</div>

					<button class="venue-cta">
						VIEW ALL VENUES
						<svg
							width="14"
							height="14"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="3"
								d="M9 5l7 7-7 7"></path>
						</svg>
					</button>
				</div>

				<!-- Right: Image with Tags -->
				<div class="venue-image-container">
					<img
						src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=800&q=80"
						alt="Fitness studio with equipment"
						class="venue-image"
					/>
					<div class="venue-tags">
						<span class="venue-tag">Fitness Studios</span>
						<span class="venue-tag">Restaurants</span>
						<span class="venue-tag">Retail Stores</span>
						<span class="venue-tag">Medical Offices</span>
						<span class="venue-tag">Coworking Spaces</span>
						<span class="venue-tag">Hotel Lobbies</span>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	/* Hero Section */
	.hero-section {
		position: relative;
		background: #000000;
		color: #ffffff;
		min-height: 100vh;
		display: flex;
		align-items: center;
		padding: 8rem 2rem 4rem;
		overflow: hidden;
	}

	.hero-pattern {
		position: absolute;
		inset: 0;
		opacity: 0.03;
		background-image: radial-gradient(
			circle at 2px 2px,
			#ffffff 1px,
			transparent 0
		);
		background-size: 40px 40px;
	}

	.hero-container {
		max-width: 90rem;
		margin: 0 auto;
		width: 100%;
		position: relative;
		z-index: 10;
	}

	.hero-label {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		color: #ff5c00;
		margin-bottom: 3rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.separator {
		color: rgba(255, 255, 255, 0.3);
	}

	.hero-heading {
		font-size: clamp(3rem, 12vw, 9rem);
		font-weight: 800;
		line-height: 0.9;
		letter-spacing: -0.02em;
		margin-bottom: 2.5rem;
		text-transform: uppercase;
	}

	.hero-heading-line {
		display: block;
	}

	.hero-heading-accent {
		color: #ff5c00;
		font-style: italic;
	}

	.hero-description {
		font-size: 15px;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.6);
		margin-bottom: 3rem;
		max-width: 600px;
	}

	.hero-cta {
		background: #ff5c00;
		color: #000000;
		border: none;
		padding: 1.125rem 2.5rem;
		font-size: 11px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		cursor: pointer;
		transition: background 0.2s;
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		border-radius: 0;
		margin-bottom: 6rem;
	}

	.hero-cta:hover {
		background: #ffffff;
	}

	.hero-stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 3rem;
		padding-top: 3rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		max-width: 1200px;
	}

	.hero-stat {
		text-align: left;
	}

	.hero-stat-number {
		font-size: 2.5rem;
		font-weight: 800;
		margin-bottom: 0.5rem;
		color: #ffffff;
	}

	.hero-stat-label {
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: rgba(255, 255, 255, 0.4);
	}

	.hero-scroll {
		background: none;
		border: none;
		color: rgba(255, 255, 255, 0.4);
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0;
		transition: color 0.2s;
	}

	.hero-scroll:hover {
		color: #ff5c00;
	}

	/* Services Section */
	.services-section {
		background: #ffffff;
		padding: 6rem 2rem;
		border-bottom: 1px solid rgba(0, 0, 0, 0.08);
	}

	.services-container {
		max-width: 90rem;
		margin: 0 auto;
	}

	.services-header {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		margin-bottom: 5rem;
	}

	@media (min-width: 1024px) {
		.services-header {
			grid-template-columns: 1fr 1fr;
			gap: 6rem;
		}
	}

	.services-label {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		color: #ff5c00;
		display: block;
		margin-bottom: 2rem;
	}

	.services-title {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		font-weight: 800;
		line-height: 1;
		letter-spacing: -0.02em;
	}

	.services-title-main {
		display: block;
		color: #000000;
	}

	.services-title-sub {
		display: block;
		color: rgba(0, 0, 0, 0.25);
	}

	.services-description {
		font-size: 15px;
		line-height: 1.7;
		color: rgba(0, 0, 0, 0.6);
		max-width: 500px;
	}

	.services-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	@media (min-width: 768px) {
		.services-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 3rem;
		}
	}

	.service-card {
		position: relative;
		padding: 2.5rem 0;
		border-top: 1px solid rgba(0, 0, 0, 0.08);
	}

	.service-number {
		position: absolute;
		top: 2.5rem;
		right: 0;
		font-size: 11px;
		font-weight: 700;
		color: #ff5c00;
		letter-spacing: 0.1em;
	}

	.service-icon {
		color: rgba(0, 0, 0, 0.4);
		margin-bottom: 1.5rem;
	}

	.service-card-title {
		font-size: 18px;
		font-weight: 800;
		margin-bottom: 1rem;
		line-height: 1.3;
	}

	.service-card-description {
		font-size: 14px;
		line-height: 1.7;
		color: rgba(0, 0, 0, 0.6);
	}

	/* Responsive */
	@media (max-width: 768px) {
		.hero-section {
			padding: 6rem 1.5rem 3rem;
		}

		.hero-heading {
			font-size: clamp(2.5rem, 10vw, 4rem);
		}

		.hero-stats {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.services-section {
			padding: 4rem 1.5rem;
		}
	}

	/* Venue Network Section */
	.venue-section {
		background: #000000;
		color: #ffffff;
		padding: 6rem 2rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}

	.venue-container {
		max-width: 90rem;
		margin: 0 auto;
	}

	.venue-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}

	@media (min-width: 1024px) {
		.venue-grid {
			grid-template-columns: 1fr 1fr;
			gap: 6rem;
		}
	}

	.venue-label {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		color: #ff5c00;
		display: block;
		margin-bottom: 2rem;
	}

	.venue-title {
		font-size: clamp(2.5rem, 6vw, 4rem);
		font-weight: 800;
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin-bottom: 1.5rem;
	}

	.venue-description {
		font-size: 15px;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.6);
		margin-bottom: 3rem;
		max-width: 500px;
	}

	.venue-stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		padding: 2rem 0;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		margin-bottom: 3rem;
	}

	.venue-stat-number {
		font-size: 2rem;
		font-weight: 800;
		margin-bottom: 0.5rem;
	}

	.venue-stat-label {
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: rgba(255, 255, 255, 0.5);
	}

	.venue-cta {
		background: transparent;
		color: #ffffff;
		border: 2px solid #ffffff;
		padding: 1rem 2rem;
		font-size: 11px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		cursor: pointer;
		transition: all 0.2s;
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		border-radius: 0;
	}

	.venue-cta:hover {
		background: #ffffff;
		color: #000000;
	}

	.venue-image-container {
		position: relative;
		border-radius: 0;
		overflow: hidden;
	}

	.venue-image {
		width: 100%;
		height: 500px;
		object-fit: cover;
		display: block;
	}

	.venue-tags {
		position: absolute;
		bottom: 1.5rem;
		left: 1.5rem;
		right: 1.5rem;
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.venue-tag {
		background: rgba(0, 0, 0, 0.8);
		backdrop-filter: blur(10px);
		color: #ffffff;
		padding: 0.625rem 1.25rem;
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		border-radius: 0;
		border: 1px solid rgba(255, 255, 255, 0.2);
	}

	@media (max-width: 1024px) {
		.venue-section {
			padding: 4rem 1.5rem;
		}

		.venue-stats {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.venue-image {
			height: 400px;
		}
	}
</style>
