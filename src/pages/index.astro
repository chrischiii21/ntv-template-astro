---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Map from "../components/Map.astro";
---

<Layout title="NTV Pulse Clone - Denver Marketing">
	<!-- Hero Section -->
	<section class="hero-section">
		<div class="hero-pattern"></div>

		<div class="hero-container">
			<div class="hero-label">
				<span>PREMIUM MARKETING</span>
				<span class="separator">·</span>
				<span>DENVER, CO</span>
			</div>

			<h1 class="hero-heading">
				<span class="hero-heading-line">GET YOUR</span>
				<span class="hero-heading-line hero-heading-accent"
					>BUSINESS</span
				>
				<span class="hero-heading-line">NOTICED.</span>
			</h1>

			<p class="hero-description">
				Denver's sharpest advertising and digital marketing<br />
				team — on screens, on search, and everywhere<br />
				your customers are.
			</p>

			<button class="hero-cta">
				TALK TO OUR TEAM
				<svg
					width="16"
					height="16"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="3"
						d="M9 5l7 7-7 7"></path>
				</svg>
			</button>

			<div class="hero-stats">
				<div class="hero-stat">
					<div class="hero-stat-number">500+</div>
					<div class="hero-stat-label">Screens Deployed</div>
				</div>
				<div class="hero-stat">
					<div class="hero-stat-number">20+</div>
					<div class="hero-stat-label">Years of Expertise</div>
				</div>
				<div class="hero-stat">
					<div class="hero-stat-number">1,200+</div>
					<div class="hero-stat-label">Clients Served</div>
				</div>
				<button class="hero-scroll">
					SCROLL
					<svg
						width="12"
						height="12"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="3"
							d="M19 9l-7 7-7-7"></path>
					</svg>
				</button>
			</div>
		</div>
	</section>
</Layout>

<!-- Services Section -->
<section class="section-white">
	<div class="section-container">
		<div class="section-grid">
			<div class="section-header">
				<span class="section-label">OUR SERVICES</span>
				<h2 class="section-title">
					LOCAL ADVERTISING SOLUTIONS FOR DENVER BUSINESSES
				</h2>
			</div>

			<div class="section-content">
				<p class="section-description">
					As your trusted Denver marketing pros, our billboard network
					gives you access to high-traffic locations where your ideal
					customers spend time.
				</p>

				<div class="service-list">
					<div class="service-item">
						<h3 class="service-title">
							INDOOR BILLBOARD ADVERTISING
						</h3>
						<p class="service-description">
							High-impact advertising in premium indoor locations
							across Denver.
						</p>
					</div>
					<div class="service-item">
						<h3 class="service-title">SOCIAL MEDIA MARKETING</h3>
						<p class="service-description">
							Build and engage your audience with strategic social
							media content.
						</p>
					</div>
					<div class="service-item">
						<h3 class="service-title">CUSTOM WEBSITE DESIGN</h3>
						<p class="service-description">
							Professional websites that convert visitors into
							customers.
						</p>
					</div>
					<div class="service-item">
						<h3 class="service-title">TARGETED LEAD GENERATION</h3>
						<p class="service-description">
							Strategic campaigns that generate quality leads and
							maximize ROI.
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Venue Partner Network Section -->
<section class="section-paper">
	<div class="section-container">
		<div class="section-grid">
			<div class="section-header">
				<span class="section-label">NETWORK COVERAGE</span>
				<h2 class="section-title">
					DENVER'S PREMIER VENUE PARTNER NETWORK
				</h2>
			</div>

			<div class="section-content">
				<p class="section-description">
					Exclusive partnerships with Denver's most popular venues
					reaching customers when they're engaged and ready to take
					action.
				</p>

				<div class="stats-grid">
					<div class="stat-card">
						<div class="stat-number">50+</div>
						<div class="stat-label">PREMIUM VENUES</div>
					</div>
					<div class="stat-card">
						<div class="stat-number">2M+</div>
						<div class="stat-label">MONTHLY VIEWS</div>
					</div>
				</div>

				<button class="btn-primary">
					VIEW VENUE PARTNERS
					<svg
						width="14"
						height="14"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="3"
							d="M9 5l7 7-7 7"></path>
					</svg>
				</button>
			</div>
		</div>
	</div>
</section>

<!-- FAQ Section -->
<section class="section-white">
	<div class="section-container">
		<div class="section-grid">
			<div class="section-header sticky-header">
				<span class="section-label">FAQ</span>
				<h2 class="section-title">FREQUENTLY ASKED QUESTIONS</h2>
				<p class="section-description">
					Find answers to common questions about our services.
				</p>
			</div>

			<div class="section-content">
				<div class="faq-list">
					<div class="faq-item">
						<button class="faq-button">
							<h3 class="faq-question">
								WHAT IS INDOOR DIGITAL SIGNAGE ADVERTISING?
							</h3>
							<svg
								class="faq-icon"
								width="24"
								height="24"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M12 4v16m8-8H4"></path>
							</svg>
						</button>
						<div class="faq-answer hidden">
							<p>
								It's the placement of your ads on TV screens
								located inside high-traffic venues, offering
								brand visibility where people are already
								engaged.
							</p>
						</div>
					</div>

					<div class="faq-item">
						<button class="faq-button">
							<h3 class="faq-question">
								DO YOU OFFER PACKAGES THAT INCLUDE SCREENS AND
								ONLINE ADS?
							</h3>
							<svg
								class="faq-icon"
								width="24"
								height="24"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M12 4v16m8-8H4"></path>
							</svg>
						</button>
						<div class="faq-answer hidden">
							<p>
								Yes! We offer comprehensive marketing packages
								that combine indoor digital signage with online
								advertising campaigns.
							</p>
						</div>
					</div>

					<div class="faq-item">
						<button class="faq-button">
							<h3 class="faq-question">
								CAN YOU HELP MY BUSINESS RANK ON GOOGLE?
							</h3>
							<svg
								class="faq-icon"
								width="24"
								height="24"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M12 4v16m8-8H4"></path>
							</svg>
						</button>
						<div class="faq-answer hidden">
							<p>
								Absolutely! Our digital marketing services
								include Google Business Profile optimization,
								local SEO strategies, and PPC campaign
								management.
							</p>
						</div>
					</div>

					<div class="faq-item">
						<button class="faq-button">
							<h3 class="faq-question">
								HOW LONG DOES IT TAKE TO SEE RESULTS?
							</h3>
							<svg
								class="faq-icon"
								width="24"
								height="24"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M12 4v16m8-8H4"></path>
							</svg>
						</button>
						<div class="faq-answer hidden">
							<p>
								Results vary by service. Indoor advertising
								campaigns typically show immediate brand
								visibility, while digital marketing efforts like
								SEO may take 3-6 months.
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- CTA Section -->
<section class="cta-section">
	<div class="cta-container">
		<div class="cta-grid">
			<div class="cta-header">
				<h2 class="cta-title">
					PARTNER WITH DENVER'S LOCAL ADVERTISING & DIGITAL MARKETING
					PROS
				</h2>
			</div>
			<div class="cta-content">
				<p class="cta-description">
					Whether you're looking for screen ads, a new website, or a
					complete digital marketing strategy in Denver, we're here to
					help.
				</p>
				<div class="cta-buttons">
					<button class="btn-cta-primary">
						SCHEDULE FREE CONSULTATION
						<svg
							width="14"
							height="14"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="3"
								d="M9 5l7 7-7 7"></path>
						</svg>
					</button>
					<button class="btn-cta-secondary"> LEARN MORE </button>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const faqButtons = document.querySelectorAll(".faq-button");

		faqButtons.forEach((button) => {
			button.addEventListener("click", () => {
				const faqItem = button.closest(".faq-item");
				const answer = faqItem?.querySelector(".faq-answer");
				const icon = button.querySelector(".faq-icon");

				if (answer && icon) {
					const isOpen = !answer.classList.contains("hidden");

					if (isOpen) {
						answer.classList.add("hidden");
						icon.style.transform = "rotate(0deg)";
					} else {
						answer.classList.remove("hidden");
						icon.style.transform = "rotate(45deg)";
					}
				}
			});
		});
	});
</script>

<style>
	/* Hero Section */
	.hero-section {
		position: relative;
		background: #000000;
		color: #ffffff;
		min-height: 100vh;
		display: flex;
		align-items: center;
		padding: 8rem 2rem 4rem;
		overflow: hidden;
	}

	.hero-pattern {
		position: absolute;
		inset: 0;
		opacity: 0.03;
		background-image: radial-gradient(
			circle at 2px 2px,
			#ffffff 1px,
			transparent 0
		);
		background-size: 40px 40px;
	}

	.hero-container {
		max-width: 90rem;
		margin: 0 auto;
		width: 100%;
		position: relative;
		z-index: 10;
	}

	.hero-label {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		color: #ff5c00;
		margin-bottom: 3rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.separator {
		color: rgba(255, 255, 255, 0.3);
	}

	.hero-heading {
		font-size: clamp(3rem, 12vw, 9rem);
		font-weight: 800;
		line-height: 0.9;
		letter-spacing: -0.02em;
		margin-bottom: 2.5rem;
		text-transform: uppercase;
	}

	.hero-heading-line {
		display: block;
	}

	.hero-heading-accent {
		color: #ff5c00;
		font-style: italic;
	}

	.hero-description {
		font-size: 15px;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.6);
		margin-bottom: 3rem;
		max-width: 600px;
	}

	.hero-cta {
		background: #ff5c00;
		color: #000000;
		border: none;
		padding: 1.125rem 2.5rem;
		font-size: 11px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		cursor: pointer;
		transition: background 0.2s;
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		border-radius: 0;
		margin-bottom: 6rem;
	}

	.hero-cta:hover {
		background: #ffffff;
	}

	.hero-stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 3rem;
		padding-top: 3rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		max-width: 1200px;
	}

	.hero-stat {
		text-align: left;
	}

	.hero-stat-number {
		font-size: 2.5rem;
		font-weight: 800;
		margin-bottom: 0.5rem;
		color: #ffffff;
	}

	.hero-stat-label {
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: rgba(255, 255, 255, 0.4);
	}

	.hero-scroll {
		background: none;
		border: none;
		color: rgba(255, 255, 255, 0.4);
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0;
		transition: color 0.2s;
	}

	.hero-scroll:hover {
		color: #ff5c00;
	}

	/* Section Styles */
	.section-white {
		background: #ffffff;
		padding: 6rem 2rem;
		border-bottom: 1px solid rgba(0, 0, 0, 0.08);
	}

	.section-paper {
		background: #f9f9f7;
		padding: 6rem 2rem;
		border-bottom: 1px solid rgba(0, 0, 0, 0.08);
	}

	.section-container {
		max-width: 90rem;
		margin: 0 auto;
	}

	.section-grid {
		display: grid;
		grid-template-columns: repeat(12, 1fr);
		gap: 3rem;
	}

	.section-header {
		grid-column: span 12;
	}

	.section-content {
		grid-column: span 12;
	}

	@media (min-width: 1024px) {
		.section-header {
			grid-column: span 5;
		}

		.section-content {
			grid-column: span 7;
		}

		.sticky-header {
			position: sticky;
			top: 8rem;
		}
	}

	.section-label {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		color: #ff5c00;
		display: block;
		margin-bottom: 2rem;
	}

	.section-title {
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 800;
		line-height: 1;
		letter-spacing: -0.02em;
		text-transform: uppercase;
		margin-bottom: 2rem;
	}

	.section-description {
		font-size: 15px;
		line-height: 1.7;
		color: rgba(0, 0, 0, 0.6);
		margin-bottom: 3rem;
	}

	/* Service List */
	.service-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.service-item {
		padding: 2rem 0;
		border-top: 1px solid rgba(0, 0, 0, 0.08);
	}

	.service-title {
		font-size: 16px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.75rem;
	}

	.service-description {
		font-size: 14px;
		line-height: 1.6;
		color: rgba(0, 0, 0, 0.6);
	}

	/* Stats Grid */
	.stats-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 2rem;
		margin-bottom: 3rem;
	}

	.stat-card {
		background: #ffffff;
		padding: 2rem;
		border: 1px solid rgba(0, 0, 0, 0.08);
		border-radius: 0;
	}

	.stat-number {
		font-size: 2.5rem;
		font-weight: 800;
		color: #ff5c00;
		margin-bottom: 0.5rem;
	}

	.stat-label {
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: rgba(0, 0, 0, 0.6);
	}

	/* Buttons */
	.btn-primary {
		background: #000000;
		color: #ffffff;
		border: none;
		padding: 1rem 2rem;
		font-size: 11px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		cursor: pointer;
		transition: background 0.2s;
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		border-radius: 0;
	}

	.btn-primary:hover {
		background: #ff5c00;
	}

	/* FAQ */
	.faq-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.faq-item {
		background: #ffffff;
		border-top: 1px solid rgba(0, 0, 0, 0.08);
	}

	.faq-button {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 2rem 0;
		background: none;
		border: none;
		cursor: pointer;
		text-align: left;
		transition: none;
	}

	.faq-button:hover {
		background: rgba(0, 0, 0, 0.02);
	}

	.faq-question {
		font-size: 16px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding-right: 2rem;
	}

	.faq-icon {
		flex-shrink: 0;
		transition: transform 0.3s;
	}

	.faq-answer {
		padding: 0 0 2rem 0;
	}

	.faq-answer.hidden {
		display: none;
	}

	.faq-answer p {
		font-size: 14px;
		line-height: 1.7;
		color: rgba(0, 0, 0, 0.6);
	}

	/* CTA Section */
	.cta-section {
		background: #000000;
		color: #ffffff;
		padding: 6rem 2rem;
	}

	.cta-container {
		max-width: 90rem;
		margin: 0 auto;
	}

	.cta-grid {
		display: grid;
		grid-template-columns: repeat(12, 1fr);
		gap: 3rem;
		align-items: center;
	}

	.cta-header {
		grid-column: span 12;
	}

	.cta-content {
		grid-column: span 12;
	}

	@media (min-width: 1024px) {
		.cta-header {
			grid-column: span 5;
		}

		.cta-content {
			grid-column: span 7;
		}
	}

	.cta-title {
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 800;
		line-height: 1;
		letter-spacing: -0.02em;
		text-transform: uppercase;
	}

	.cta-description {
		font-size: 15px;
		line-height: 1.7;
		color: rgba(255, 255, 255, 0.6);
		margin-bottom: 2rem;
	}

	.cta-buttons {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.btn-cta-primary {
		background: #ff5c00;
		color: #000000;
		border: none;
		padding: 1.125rem 2rem;
		font-size: 11px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		cursor: pointer;
		transition: background 0.2s;
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		border-radius: 0;
	}

	.btn-cta-primary:hover {
		background: #ffffff;
	}

	.btn-cta-secondary {
		background: transparent;
		color: #ffffff;
		border: 2px solid #ffffff;
		padding: 1.125rem 2rem;
		font-size: 11px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		cursor: pointer;
		transition: all 0.2s;
		border-radius: 0;
	}

	.btn-cta-secondary:hover {
		background: #ffffff;
		color: #000000;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.hero-section {
			padding: 6rem 1.5rem 3rem;
		}

		.hero-heading {
			font-size: clamp(2.5rem, 10vw, 4rem);
		}

		.hero-stats {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.section-white,
		.section-paper,
		.cta-section {
			padding: 4rem 1.5rem;
		}
	}
</style>
