---
// FloatingFreeScanButton.astro - Floating "FREE SCAN" button matching site design
---

<div id="floating-scan-button" class="fixed bottom-8 right-8 z-[9999] hidden">
    <!-- Close Button -->
    <button
        id="scan-close-btn"
        class="absolute -top-2 -right-2 w-6 h-6 bg-red-600 hover:bg-red-700 text-white rounded-full flex items-center justify-center text-sm font-bold transition-all duration-200 hover:scale-110 shadow-lg z-10"
        aria-label="Close FREE SCAN button"
        type="button"
    >
        ×
    </button>

    <!-- Main Button -->
    <button
        id="scan-main-btn"
        class="bg-[#06B6D4] text-black border-none px-8 py-4 text-[11px] font-bold uppercase tracking-[0.1em] cursor-pointer transition-all duration-300 inline-flex items-center gap-3 rounded-none shadow-2xl hover:scale-105 hover:shadow-[#06B6D4]/50"
        type="button"
    >
        <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span>FREE SCAN</span>
        <svg
            width="14"
            height="14"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="3"
                d="M9 5l7 7-7 7"></path>
        </svg>
    </button>
</div>

<script>
    // Ensure script only runs once
    declare global {
        interface Window {
            floatingScanButtonInitialized?: boolean;
        }
    }

    if (!window.floatingScanButtonInitialized) {
        window.floatingScanButtonInitialized = true;

        document.addEventListener("DOMContentLoaded", () => {
            const floatingButton = document.getElementById(
                "floating-scan-button",
            ) as HTMLElement;
            const closeBtn = document.getElementById(
                "scan-close-btn",
            ) as HTMLButtonElement;
            const mainBtn = document.getElementById(
                "scan-main-btn",
            ) as HTMLButtonElement;

            if (!floatingButton) return;

            // Check if user has previously dismissed the button
            const isDismissed = localStorage.getItem(
                "free-scan-floating-dismissed",
            );
            if (isDismissed) {
                return;
            }

            // Show button after 3 seconds
            setTimeout(() => {
                floatingButton.classList.remove("hidden");
                floatingButton.style.opacity = "0";
                floatingButton.style.transform = "translateY(100px)";

                requestAnimationFrame(() => {
                    floatingButton.style.transition =
                        "all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1)";
                    floatingButton.style.opacity = "1";
                    floatingButton.style.transform = "translateY(0)";
                });
            }, 3000);

            // Close button functionality
            if (closeBtn) {
                closeBtn.addEventListener("click", (e) => {
                    e.preventDefault();
                    e.stopPropagation();

                    floatingButton.style.transition = "all 0.4s ease-out";
                    floatingButton.style.opacity = "0";
                    floatingButton.style.transform = "translateY(100px)";

                    setTimeout(() => {
                        floatingButton.classList.add("hidden");
                        localStorage.setItem(
                            "free-scan-floating-dismissed",
                            "true",
                        );
                    }, 400);
                });
            }

            // Main button click functionality
            if (mainBtn) {
                mainBtn.addEventListener("click", () => {
                    const ctaSection = document.querySelector(
                        "section.bg-\\[\\#06B6D4\\]",
                    );
                    if (ctaSection) {
                        ctaSection.scrollIntoView({
                            behavior: "smooth",
                            block: "start",
                        });
                    } else {
                        window.scrollTo({
                            top: document.body.scrollHeight,
                            behavior: "smooth",
                        });
                    }
                });
            }
        });
    }
</script>

<style>
    #floating-scan-button {
        position: relative;
    }

    /* Mobile responsiveness */
    @media (max-width: 640px) {
        #floating-scan-button {
            bottom: 1.5rem;
            right: 1.5rem;
        }

        #scan-main-btn {
            padding: 0.875rem 1.5rem;
            font-size: 10px;
        }

        #scan-main-btn svg:first-of-type {
            width: 1rem;
            height: 1rem;
        }

        #scan-main-btn svg:last-of-type {
            width: 12px;
            height: 12px;
        }
    }
</style>
