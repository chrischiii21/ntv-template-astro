---
import { Image } from "astro:assets";
import logo from "../assets/dealer-logo.avif";
---

<style>
    nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        background: rgba(0, 0, 0, 0.95);
        backdrop-filter: blur(10px);
        transition:
            background 0.3s,
            box-shadow 0.3s;
    }

    nav.scrolled {
        background: rgba(255, 255, 255, 0.98);
        box-shadow: 0 1px 0 rgba(0, 0, 0, 0.08);
    }

    nav.scrolled .logo-text,
    nav.scrolled .nav-links a {
        color: #000000;
    }

    nav.scrolled .nav-links a {
        color: rgba(0, 0, 0, 0.6);
    }

    nav.scrolled .nav-links a:hover {
        color: #ff5c00;
    }

    nav.scrolled .nav-meta {
        color: rgba(0, 0, 0, 0.4);
    }

    nav.scrolled .mobile-menu-btn {
        color: #000000;
    }

    .nav-container {
        max-width: 90rem;
        margin: 0 auto;
        padding: 1.5rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 4rem;
    }

    .logo-container {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .logo-circle {
        width: 40px;
        height: 40px;
        background: #ff5c00;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .logo-text {
        font-size: 14px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: #ffffff;
    }

    .nav-links {
        display: none;
        gap: 2.5rem;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.2em;
    }

    @media (min-width: 1024px) {
        .nav-links {
            display: flex;
        }
    }

    .nav-links a {
        color: rgba(255, 255, 255, 0.6);
        text-decoration: none;
        transition: color 0.2s;
    }

    .nav-links a:hover {
        color: #ff5c00;
    }

    .nav-right {
        display: flex;
        align-items: center;
        gap: 3rem;
    }

    .nav-meta {
        display: none;
        text-align: right;
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(255, 255, 255, 0.4);
        line-height: 1.4;
    }

    @media (min-width: 1024px) {
        .nav-meta {
            display: block;
        }
    }

    .contact-btn {
        background: #ff5c00;
        color: #000000;
        border: none;
        padding: 0.875rem 1.75rem;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        cursor: pointer;
        transition: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border-radius: 0;
    }

    .contact-btn:hover {
        background: #ffffff;
    }

    .contact-btn svg {
        width: 14px;
        height: 14px;
    }

    .mobile-menu-btn {
        display: block;
        color: #ffffff;
        background: none;
        border: none;
        padding: 0.5rem;
        cursor: pointer;
    }

    @media (min-width: 1024px) {
        .mobile-menu-btn {
            display: none;
        }
    }
</style>

<nav>
    <div class="nav-container">
        <div class="nav-left">
            <a href="/" class="logo-container">
                <div class="logo-circle">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 20 20"
                        fill="white"
                    >
                        <circle cx="10" cy="10" r="3"></circle>
                    </svg>
                </div>
                <span class="logo-text">Apex Denver</span>
            </a>

            <div class="nav-links">
                <a href="#about">About</a>
                <a href="#billboards">Billboards</a>
                <a href="#solutions">Solutions</a>
            </div>
        </div>

        <div class="nav-right">
            <div class="nav-meta">
                <div>EST. 2024</div>
                <div>DENVER LOCALS</div>
            </div>

            <button class="contact-btn">
                Contact
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="3"
                        d="M9 5l7 7-7 7"></path>
                </svg>
            </button>

            <button class="mobile-menu-btn">
                <svg
                    width="24"
                    height="24"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </div>
</nav>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const nav = document.querySelector("nav");

        window.addEventListener("scroll", () => {
            if (window.scrollY > 100) {
                nav?.classList.add("scrolled");
            } else {
                nav?.classList.remove("scrolled");
            }
        });
    });
</script>
