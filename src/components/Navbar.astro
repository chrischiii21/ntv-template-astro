---
import { Image } from "astro:assets";
import logo from "../assets/dealer-logo.avif";
---

<nav class="fixed top-4 left-0 right-0 z-50 px-4 md:px-6">
    <div
        class="max-w-7xl mx-auto bg-white/95 backdrop-blur-md rounded-xl md:rounded-2xl border border-slate-200 shadow-lg px-4 md:px-8 h-16 md:h-20 flex justify-between items-center"
    >
        <div class="flex items-center gap-6 md:gap-12">
            <a
                href="/"
                class="flex items-center transition-transform hover:scale-105"
            >
                <Image
                    src={logo}
                    alt="Dashboard Logo"
                    width={40}
                    height={40}
                    format="avif"
                    loading="eager"
                    class="rounded-lg object-contain md:w-12 md:h-12"
                />
            </a>

            <div
                class="hidden md:flex gap-6 lg:gap-8 text-sm font-medium text-slate-700"
            >
                <a
                    href="/"
                    class="text-slate-900 font-semibold hover:text-slate-600 transition-colors"
                    >Home</a
                >
                <a href="#" class="hover:text-slate-900 transition-colors"
                    >About Us</a
                >
                <a
                    href="#"
                    class="hover:text-slate-900 transition-colors flex items-center gap-1"
                >
                    Indoor Billboards
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M19 9l-7 7-7-7"></path>
                    </svg>
                </a>
                <a
                    href="#"
                    class="hover:text-slate-900 transition-colors flex items-center gap-1"
                >
                    Solutions
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M19 9l-7 7-7-7"></path>
                    </svg>
                </a>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <button
                class="bg-slate-900 text-white text-xs md:text-sm font-semibold px-4 md:px-6 py-2 md:py-2.5 rounded-lg hover:bg-slate-800 transition-all shadow-md hover:shadow-lg uppercase tracking-wide"
            >
                Contact Us
            </button>

            <!-- Mobile menu button -->
            <button class="md:hidden text-slate-700 hover:text-slate-900 p-2">
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </div>
</nav>
