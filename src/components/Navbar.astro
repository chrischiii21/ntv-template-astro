---

---

<nav
    class="nav-bar fixed top-0 left-0 right-0 z-50 bg-black/95 backdrop-blur-[10px] transition-all duration-300"
>
    <div
        class="max-w-[90rem] mx-auto px-8 py-6 flex justify-between items-center"
    >
        <div class="flex items-center gap-16">
            <a href="/" class="flex items-center gap-3">
                <div
                    class="w-10 h-10 bg-[#06B6D4] rounded-full flex items-center justify-center overflow-hidden p-1"
                >
                    <div
                        class="w-full h-full bg-white rounded-full flex items-center justify-center"
                    >
                        <img
                            src="/dealer-logo.avif"
                            alt="Logo"
                            class="w-5 h-5 object-contain"
                            width="20"
                            height="20"
                        />
                    </div>
                </div>
                <span
                    class="nav-logo-text text-[14px] font-extrabold uppercase tracking-[0.15em] text-white"
                    >Denver Marketing</span
                >
            </a>

            <div
                class="hidden lg:flex gap-10 text-[11px] font-bold uppercase tracking-[0.2em]"
            >
                <a
                    href="#home"
                    class="nav-link text-white/60 no-underline transition-colors duration-200 hover:text-[#06B6D4]"
                    >Home</a
                >
                <a
                    href="#about"
                    class="nav-link text-white/60 no-underline transition-colors duration-200 hover:text-[#06B6D4]"
                    >About Us</a
                >

                <!-- Billboards Dropdown -->
                <div class="relative group">
                    <button
                        class="nav-link text-white/60 no-underline transition-colors duration-200 hover:text-[#06B6D4] flex items-center gap-1"
                    >
                        Billboards
                        <svg
                            class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </button>
                    <div
                        class="absolute top-full left-0 mt-2 w-[420px] bg-white shadow-xl rounded-none border border-black/10 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 p-8"
                    >
                        <!-- Become a Venue Partner -->
                        <a
                            href="#partner"
                            class="flex gap-4 p-4 rounded-none hover:bg-[#06B6D4]/5 transition-colors group/item mb-4"
                        >
                            <div
                                class="w-10 h-10 bg-[#06B6D4]/10 rounded-full flex items-center justify-center shrink-0"
                            >
                                <svg
                                    class="w-5 h-5 text-[#06B6D4]"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h4
                                    class="text-[13px] font-bold text-black mb-1 group-hover/item:text-[#06B6D4] transition-colors normal-case"
                                >
                                    Become a Venue Partner
                                </h4>
                                <p
                                    class="text-[11px] font-normal text-black/60 py-3 normal-case"
                                >
                                    Are you interested in partnering with us to
                                    display ads at your location?
                                </p>
                            </div>
                        </a>

                        <!-- Locations -->
                        <a
                            href="#locations"
                            class="flex gap-4 p-4 rounded-none hover:bg-[#06B6D4]/5 transition-colors group/item mb-4"
                        >
                            <div
                                class="w-10 h-10 bg-[#06B6D4]/10 rounded-full flex items-center justify-center shrink-0"
                            >
                                <svg
                                    class="w-5 h-5 text-[#06B6D4]"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                    ></path>
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h4
                                    class="text-[13px] font-bold text-black mb-1 group-hover/item:text-[#06B6D4] transition-colors normal-case"
                                >
                                    Locations
                                </h4>
                                <p
                                    class="text-[11px] py-3 font-normal leading-[1.5] text-black/60 normal-case"
                                >
                                    See the map of indoor digital signage
                                    locations across Denver.
                                </p>
                            </div>
                        </a>

                        <!-- Screen Advertising -->
                        <a
                            href="#screen"
                            class="flex gap-4 p-4 rounded-none hover:bg-[#06B6D4]/5 transition-colors group/item"
                        >
                            <div
                                class="w-10 h-10 bg-[#06B6D4]/10 rounded-full flex items-center justify-center shrink-0"
                            >
                                <svg
                                    class="w-5 h-5 text-[#06B6D4]"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h4
                                    class="text-[13px] font-bold text-black mb-1 group-hover/item:text-[#06B6D4] transition-colors normal-case"
                                >
                                    Screen Advertising
                                </h4>
                                <p
                                    class="text-[11px] py-3 font-normal leading-[1.5] text-black/60 normal-case"
                                >
                                    Advertise on screens in key local areas to
                                    reach your target audience.
                                </p>
                            </div>
                        </a>
                    </div>
                </div>

                <!-- Solutions Dropdown -->
                <div class="relative group">
                    <button
                        class="nav-link text-white/60 no-underline transition-colors duration-200 hover:text-[#06B6D4] flex items-center gap-1"
                    >
                        Solutions
                        <svg
                            class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </button>
                    <div
                        class="absolute top-full left-0 mt-2 w-[600px] bg-white shadow-xl rounded-none border border-black/10 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 p-8"
                    >
                        <!-- Header -->
                        <div class="mb-6">
                            <p
                                class="text-[10px] font-bold uppercase tracking-[0.15em] text-[#06B6D4] mb-2"
                            >
                                FOUNDATIONS
                            </p>
                        </div>

                        <!-- Grid -->
                        <div class="grid grid-cols-2 gap-6">
                            <!-- Industry Design -->
                            <a
                                href="#industry"
                                class="flex gap-4 p-4 rounded-none hover:bg-[#06B6D4]/5 transition-colors group/item"
                            >
                                <div
                                    class="w-10 h-10 bg-[#06B6D4]/10 rounded-full flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-5 h-5 text-[#06B6D4]"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h4
                                        class="text-[13px] font-bold text-black mb-1 group-hover/item:text-[#06B6D4] transition-colors normal-case"
                                    >
                                        Industry Design
                                    </h4>
                                    <p
                                        class="text-[11px] py-3 font-normal leading-[1.5] text-black/60 normal-case"
                                    >
                                        Stand out among the competition with
                                        custom branding and design.
                                    </p>
                                </div>
                            </a>

                            <!-- Google Business Profile -->
                            <a
                                href="#google"
                                class="flex gap-4 p-4 rounded-none hover:bg-[#06B6D4]/5 transition-colors group/item"
                            >
                                <div
                                    class="w-10 h-10 bg-[#06B6D4]/10 rounded-full flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-5 h-5 text-[#06B6D4]"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h4
                                        class="text-[13px] font-bold text-black mb-1 group-hover/item:text-[#06B6D4] transition-colors normal-case"
                                    >
                                        Google Business Profile
                                    </h4>
                                    <p
                                        class="text-[11px] py-3 font-normal leading-[1.5] text-black/60 normal-case"
                                    >
                                        Get found on local searches and get
                                        listed by customers searching for you.
                                    </p>
                                </div>
                            </a>

                            <!-- Social Media Management -->
                            <a
                                href="#social"
                                class="flex gap-4 p-4 rounded-none hover:bg-[#06B6D4]/5 transition-colors group/item"
                            >
                                <div
                                    class="w-10 h-10 bg-[#06B6D4]/10 rounded-full flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-5 h-5 text-[#06B6D4]"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h4
                                        class="text-[13px] font-bold text-black mb-1 group-hover/item:text-[#06B6D4] transition-colors normal-case"
                                    >
                                        Social Media Management
                                    </h4>
                                    <p
                                        class="text-[11px] py-3 font-normal leading-[1.5] text-black/60 normal-case"
                                    >
                                        Build and engage your audience with
                                        strategic social media content.
                                    </p>
                                </div>
                            </a>

                            <!-- Design Services -->
                            <a
                                href="#design"
                                class="flex gap-4 p-4 rounded-none hover:bg-[#06B6D4]/5 transition-colors group/item"
                            >
                                <div
                                    class="w-10 h-10 bg-[#06B6D4]/10 rounded-full flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-5 h-5 text-[#06B6D4]"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h4
                                        class="text-[13px] font-bold text-black mb-1 group-hover/item:text-[#06B6D4] transition-colors normal-case"
                                    >
                                        Design Services
                                    </h4>
                                    <p
                                        class="text-[11px] py-3 font-normal leading-[1.5] text-black/60 normal-case"
                                    >
                                        Professional design that fits your brand
                                        and converts visitors.
                                    </p>
                                </div>
                            </a>
                        </div>

                        <!-- Separator -->
                        <div class="border-t border-black/10 my-6"></div>

                        <!-- Second Section -->
                        <div class="mb-4">
                            <p
                                class="text-[10px] font-bold uppercase tracking-[0.15em] text-[#06B6D4] mb-4"
                            >
                                GROWTH & AWARENESS
                            </p>
                        </div>

                        <div class="grid grid-cols-2 gap-6">
                            <!-- Connected TV -->
                            <a
                                href="#ctv"
                                class="flex gap-4 p-4 rounded-none hover:bg-[#06B6D4]/5 transition-colors group/item"
                            >
                                <div
                                    class="w-10 h-10 bg-[#06B6D4]/10 rounded-full flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-5 h-5 text-[#06B6D4]"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h4
                                        class="text-[13px] font-bold text-black mb-1 group-hover/item:text-[#06B6D4] transition-colors normal-case"
                                    >
                                        Connected TV (OTT Ads)
                                    </h4>
                                    <p
                                        class="text-[11px py-3 font-normal leading-[1.5] text-black/60 normal-case"
                                    >
                                        Reach viewers on streaming platforms and
                                        smart TVs.
                                    </p>
                                </div>
                            </a>

                            <!-- Display Geofencing -->
                            <a
                                href="#geo"
                                class="flex gap-4 p-4 rounded-none hover:bg-[#06B6D4]/5 transition-colors group/item"
                            >
                                <div
                                    class="w-10 h-10 bg-[#06B6D4]/10 rounded-full flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-5 h-5 text-[#06B6D4]"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                        ></path>
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                        ></path>
                                    </svg>
                                </div>
                                <div>
                                    <h4
                                        class="text-[13px] font-bold text-black mb-1 group-hover/item:text-[#06B6D4] transition-colors normal-case"
                                    >
                                        Display Geofencing
                                    </h4>
                                    <p
                                        class="text-[11px] py-3 font-normal leading-[1.5] text-black/60 normal-case"
                                    >
                                        Target customers based on their physical
                                        location.
                                    </p>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-12">
            <div
                class="nav-meta hidden lg:block text-right text-[10px] font-semibold uppercase tracking-[0.15em] text-white/40 leading-[1.4]"
            >
                <div>EST. 2024</div>
                <div>DENVER LOCALS</div>
            </div>

            <button
                class="bg-[#06B6D4] text-black border-none px-7 py-3.5 text-[11px] font-extrabold uppercase tracking-[0.2em] cursor-pointer transition-all duration-300 flex items-center gap-2 rounded-none hover:scale-105 hover:shadow-lg hover:shadow-[#06B6D4]/50"
            >
                Contact
                <svg
                    class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="3"
                        d="M9 5l7 7-7 7"></path>
                </svg>
            </button>

            <button
                class="mobile-menu-btn block lg:hidden text-white bg-transparent border-none p-2 cursor-pointer"
            >
                <svg
                    class="hamburger-icon"
                    width="24"
                    height="24"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
                <svg
                    class="close-icon hidden"
                    width="24"
                    height="24"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
    </div>

    <!-- Mobile Menu Overlay -->
    <div
        class="mobile-menu-overlay fixed inset-0 bg-black/50 backdrop-blur-sm opacity-0 invisible transition-all duration-300 z-30 lg:hidden"
    >
    </div>

    <!-- Mobile Menu -->
    <div
        class="mobile-menu fixed top-0 right-0 w-80 h-screen bg-black/98 backdrop-blur-lg transform translate-x-full transition-transform duration-300 z-40 lg:hidden overflow-y-auto"
    >
        <div class="flex flex-col h-full">
            <!-- Close Button -->
            <div class="flex justify-end p-6">
                <button
                    class="mobile-close-btn text-white/80 hover:text-white transition-colors p-2"
                >
                    <svg
                        width="24"
                        height="24"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

            <!-- Mobile Nav Links -->
            <div class="flex-1 px-8 pb-8">
                <div class="flex flex-col gap-8 mb-12">
                    <a
                        href="#about"
                        class="text-white/80 text-xl font-bold uppercase tracking-[0.1em] hover:text-[#06B6D4] transition-colors py-2"
                        >About Us</a
                    >

                    <!-- Mobile Billboards Section -->
                    <div>
                        <button
                            class="mobile-dropdown-btn w-full flex justify-between items-center text-white/80 text-xl font-bold uppercase tracking-[0.1em] hover:text-[#06B6D4] transition-colors py-2"
                        >
                            Billboards
                            <svg
                                class="w-5 h-5 transition-transform duration-200"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </button>
                        <div
                            class="mobile-dropdown-content hidden pl-4 mt-6 flex flex-col gap-5"
                        >
                            <a
                                href="#partner"
                                class="text-white/60 text-base hover:text-[#06B6D4] transition-colors py-1"
                                >Become a Venue Partner</a
                            >
                            <a
                                href="#locations"
                                class="text-white/60 text-base hover:text-[#06B6D4] transition-colors py-1"
                                >Locations</a
                            >
                            <a
                                href="#screen"
                                class="text-white/60 text-base hover:text-[#06B6D4] transition-colors py-1"
                                >Screen Advertising</a
                            >
                        </div>
                    </div>

                    <!-- Mobile Solutions Section -->
                    <div>
                        <button
                            class="mobile-dropdown-btn w-full flex justify-between items-center text-white/80 text-xl font-bold uppercase tracking-[0.1em] hover:text-[#06B6D4] transition-colors py-2"
                        >
                            Solutions
                            <svg
                                class="w-5 h-5 transition-transform duration-200"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </button>
                        <div
                            class="mobile-dropdown-content hidden pl-4 mt-6 flex flex-col gap-5"
                        >
                            <div
                                class="text-xs font-bold uppercase tracking-[0.15em] text-[#06B6D4] mb-3"
                            >
                                FOUNDATIONS
                            </div>
                            <a
                                href="#industry"
                                class="text-white/60 text-base hover:text-[#06B6D4] transition-colors py-1"
                                >Industry Design</a
                            >
                            <a
                                href="#google"
                                class="text-white/60 text-base hover:text-[#06B6D4] transition-colors py-1"
                                >Google Business Profile</a
                            >
                            <a
                                href="#social"
                                class="text-white/60 text-base hover:text-[#06B6D4] transition-colors py-1"
                                >Social Media Management</a
                            >
                            <a
                                href="#design"
                                class="text-white/60 text-base hover:text-[#06B6D4] transition-colors py-1"
                                >Design Services</a
                            >
                            <div
                                class="text-xs font-bold uppercase tracking-[0.15em] text-[#06B6D4] mb-3 mt-6"
                            >
                                GROWTH & AWARENESS
                            </div>
                            <a
                                href="#ctv"
                                class="text-white/60 text-base hover:text-[#06B6D4] transition-colors py-1"
                                >Connected TV (OTT Ads)</a
                            >
                            <a
                                href="#geo"
                                class="text-white/60 text-base hover:text-[#06B6D4] transition-colors py-1"
                                >Display Geofencing</a
                            >
                        </div>
                    </div>
                </div>

                <!-- Mobile Contact Button -->
                <div class="mt-auto">
                    <button
                        class="w-full bg-[#06B6D4] text-black border-none px-8 py-5 text-sm font-extrabold uppercase tracking-[0.2em] cursor-pointer transition-all duration-300 flex items-center justify-center gap-3 rounded-none hover:scale-105 hover:shadow-lg hover:shadow-[#06B6D4]/50"
                    >
                        Contact
                        <svg
                            class="w-4 h-4"
                            fill="none"
