---
// Map.astro - Interactive map component with location markers
---

<div id="map-wrapper" class="relative w-full h-full">
    <div id="map" class="w-full h-full"></div>
    <div
        id="map-location-overlay"
        class="absolute top-6 left-6 bg-blue/70 backdrop-blur-[10px] px-6 py-4 rounded-lg border border-white/20 shadow-xl z-[1001] flex flex-col gap-1 pointer-events-none"
    >
        <span
            id="map-location-name"
            class="text-[18px] font-extrabold text-black/60 tracking-[0.05em]"
        >
            AURORA
        </span>
        <span
            id="map-location-region"
            class="text-[11px] font-semibold text-black/70 uppercase tracking-[0.1em]"
        >
            East Metro
        </span>
    </div>
</div>

<script src="../scripts/map.js"></script>

<style>
    /* Global styles for Leaflet marker - cannot be converted to Tailwind */
    :global(.custom-marker-cyan) {
        background: transparent;
        border: none;
    }

    :global(.pulse-marker) {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    @keyframes pulse {
        0%,
        100% {
            opacity: 1;
        }
        50% {
            opacity: 0.7;
        }
    }

    /* Hide Leaflet attribution */
    :global(.leaflet-control-attribution) {
        display: none;
    }

    /* Ensure overlay is always visible */
    #map-location-overlay {
        position: absolute !important;
        z-index: 1001 !important;
        top: 1.5rem !important;
        left: 1.5rem !important;
    }
</style>
