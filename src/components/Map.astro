---

---

<div id="map-wrapper" class="relative w-full h-full">
    <div id="map" class="w-full h-full"></div>
    <div
        id="map-location-overlay"
        class="absolute top-6 left-6 bg-black/85 backdrop-blur-[10px] px-6 py-4 rounded-none border border-white/10 z-10 flex flex-col gap-1"
    >
        <span
            id="map-location-name"
            class="text-[18px] font-extrabold text-white tracking-[0.05em]"
            >AURORA</span
        >
        <span
            id="map-location-region"
            class="text-[11px] font-semibold text-white/50 uppercase tracking-[0.1em]"
            >East Metro</span
        >
    </div>
</div>

<script>
    import L from "leaflet";
    import "leaflet/dist/leaflet.css";

    declare global {
        interface Window {
            flyToCity: (
                lat: number,
                lng: number,
                name: string,
                region: string,
            ) => void;
        }
    }

    const map = L.map("map", {
        zoomControl: false, // Remove zoom controls
        scrollWheelZoom: false,
        doubleClickZoom: false,
        touchZoom: false,
    }).setView([39.7294, -104.8319], 12);

    // Dark theme map tiles
    L.tileLayer(
        "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png",
        {
            attribution: "© OpenStreetMap contributors © CARTO",
            subdomains: "abcd",
            maxZoom: 20,
        },
    ).addTo(map);

    // Custom orange marker icon
    const orangeIcon = L.divIcon({
        className: "custom-marker-orange",
        html: `<div class="w-12 h-12 bg-orange-500 rounded-full flex items-center justify-center shadow-2xl border-4 border-white pulse-marker">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
            </svg>
        </div>`,
        iconSize: [48, 48],
        iconAnchor: [24, 48],
    });

    // Store current marker
    let currentMarker: L.Marker | null = null;

    // Function to move map and update overlay
    window.flyToCity = (
        lat: number,
        lng: number,
        name: string,
        region: string,
    ) => {
        // Remove previous marker
        if (currentMarker) {
            map.removeLayer(currentMarker);
        }

        // Add new marker
        currentMarker = L.marker([lat, lng], { icon: orangeIcon }).addTo(map);

        // Fly to location
        map.flyTo([lat, lng], 12, {
            duration: 1.5,
        });

        // Update overlay text
        const nameElement = document.getElementById("map-location-name");
        const regionElement = document.getElementById("map-location-region");
        if (nameElement) nameElement.textContent = name.toUpperCase();
        if (regionElement) regionElement.textContent = region;
    };

    // Initialize with Aurora
    currentMarker = L.marker([39.7294, -104.8319], { icon: orangeIcon }).addTo(
        map,
    );
</script>

<style>
    /* Global styles for Leaflet marker - cannot be converted to Tailwind */
    :global(.custom-marker-orange) {
        background: transparent;
        border: none;
    }

    :global(.pulse-marker) {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    @keyframes pulse {
        0%,
        100% {
            opacity: 1;
        }
        50% {
            opacity: 0.7;
        }
    }

    /* Hide Leaflet attribution */
    :global(.leaflet-control-attribution) {
        display: none;
    }
</style>
